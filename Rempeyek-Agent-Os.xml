}
.mark text {
  font-family:"Orbitron"; font-size:34px; font-weight:900; fill:var(--acc);
  opacity:0; animation:fadeIn .6s 1.7s forwards;
}
/* shock ring on mark completion */
.ring {
  position:absolute; left:50%; top:62px; width:110px; height:110px; margin-left:-55px;
  border:1.5px solid var(--acc); border-radius:50%; opacity:0; z-index:1;
  animation:shock 1.4s 1.9s cubic-bezier(.2,.65,.3,1) forwards;
}
/* title: per-letter rise */
.title { font-size:clamp(34px,6.4vw,84px); font-weight:900; letter-spacing:.14em; color:var(--text); }
.title span {
  display:inline-block; opacity:0; transform:translateY(.55em) rotateX(60deg);
  animation:rise .7s cubic-bezier(.2,.8,.2,1) forwards;
  background:linear-gradient(90deg, var(--acc), var(--violet) 55%, var(--magenta));
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
  filter:drop-shadow(0 0 18px color-mix(in srgb, var(--acc) 30%, transparent));
}
.title .sp { width:.45em; }
/* subtitle + scanline */
.sub {
  margin-top:22px; font-family:"Cascadia Mono",Consolas,monospace; font-size:clamp(10px,1.3vw,15px);
  letter-spacing:.5em; color:var(--muted); text-transform:uppercase;
  opacity:0; animation:fadeIn 1s 3.6s forwards;
}
.beam {
  margin:26px auto 0; height:1px; width:0; background:linear-gradient(90deg, transparent, var(--acc), transparent);
  box-shadow:0 0 12px var(--acc); animation:beam 1.1s 3.2s cubic-bezier(.6,0,.2,1) forwards;
}
.tag {
  margin-top:18px; font-family:"Cascadia Mono",Consolas,monospace; font-size:clamp(9px,1vw,12px);
  letter-spacing:.3em; color:var(--acc); opacity:0; animation:fadeIn 1s 4.4s forwards;
}
/* outro fade — the JS loop restarts everything at 12s */
.stage.out .lockup, .stage.out .glow { animation:fadeOut 1s forwards; }
@keyframes draw   { to { stroke-dashoffset:0; } }
@keyframes rise   { to { opacity:1; transform:none; } }
@keyframes fadeIn { to { opacity:1; } }
@keyframes fadeOut{ to { opacity:0; } }
@keyframes beam   { to { width:min(560px,72vw); } }
@keyframes shock  { 0%{ opacity:.8; transform:scale(.4);} 100%{ opacity:0; transform:scale(3.4);} }
@media (prefers-reduced-motion: reduce) {
  .mark path { animation-duration:.01s; animation-delay:0s; }
  .title span, .sub, .tag { animation-duration:.01s; animation-delay:0s; }
  .beam { animation-duration:.01s; animation-delay:0s; }
  .ring { display:none; }
}
</style>
</head>
<body>
<div class="stage" id="stage">
  <canvas id="stars"></canvas>
  <div class="glow"></div>
  <div class="lockup">
    <svg class="mark" viewBox="0 0 100 112" aria-hidden="true">
      <path d="M50 4 L96 30 L96 82 L50 108 L4 82 L4 30 Z"/>
      <text x="50" y="68" text-anchor="middle">◈</text>
    </svg>
    <div class="ring"></div>
    <div class="title" id="title" aria-label="REMPEYEK AGENT OS"></div>
    <div class="sub">agentic operating system</div>
    <div class="beam"></div>
    <div class="tag">NEURAL COSMOS EDITION</div>
  </div>
</div>
<script>
/* per-letter stagger for the title */
const TITLE = "REMPEYEK AGENT OS";
const t = document.getElementById("title");
[...TITLE].forEach((ch, i) => {
  const s = document.createElement("span");
  if (ch === " ") { s.className = "sp"; s.innerHTML = "&nbsp;"; }
  else { s.textContent = ch; s.style.animationDelay = (2.0 + i * 0.055) + "s"; }
  t.appendChild(s);
});

/* starfield with gentle drift + accent twinkles */
const cv = document.getElementById("stars"), cx = cv.getContext("2d");
let stars = [];
function size() {
  cv.width = innerWidth * devicePixelRatio; cv.height = innerHeight * devicePixelRatio;
  stars = Array.from({ length: Math.floor(innerWidth / 6) }, () => ({
    x: Math.random() * cv.width, y: Math.random() * cv.height,
    r: (Math.random() * 1.3 + .3) * devicePixelRatio,
    v: Math.random() * .12 + .02, p: Math.random() * Math.PI * 2,
    c: Math.random() < .12 ? getComputedStyle(document.documentElement).getPropertyValue("--acc").trim() : "#EEEBFF",
  }));
}
addEventListener("resize", size); size();
(function tick(ts) {
  cx.clearRect(0, 0, cv.width, cv.height);
  for (const s of stars) {
    s.y -= s.v; if (s.y < 0) s.y = cv.height;
    const a = .25 + .55 * Math.abs(Math.sin(ts / 1400 + s.p));
    cx.globalAlpha = a; cx.fillStyle = s.c;
    cx.beginPath(); cx.arc(s.x, s.y, s.r, 0, 7); cx.fill();
  }
  cx.globalAlpha = 1;
  requestAnimationFrame(tick);
})(0);

/* 12s loop: fade out at 11s, hard-restart the CSS timeline at 12s */
const stage = document.getElementById("stage");
function loop() {
  stage.classList.remove("out");
  setTimeout(() => stage.classList.add("out"), 11000);
}
loop();
setInterval(() => {
  /* re-trigger every CSS animation by cloning the lockup's animation state */
  stage.classList.remove("out");
  const lock = stage.querySelector(".lockup");
  lock.style.animation = "none";
  lock.querySelectorAll("*").forEach(el => { const a = el.style.animationDelay; el.style.animation = "none"; void el.offsetWidth; el.style.animation = ""; el.style.animationDelay = a; });
  void lock.offsetWidth; lock.style.animation = "";
  setTimeout(() => stage.classList.add("out"), 11000);
}, 12000);
</script>
</body>
</html>
