                          <td style={{ fontFamily: "var(--mono)", fontSize: 10 }}>{a.lastSeen || "—"}</td>
                          <td><span className={`lbl-${a.gw === "running" ? "running" : "idle"}`} style={{ fontFamily: "var(--mono)", fontSize: 10 }}>{a.gw}</span></td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
