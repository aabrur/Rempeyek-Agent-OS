<file path="packages/design-system/src/index.css">
/* @rempeyek/design-system — the neural command deck stylesheet.
   Base :root values are fallbacks; four structural modes override them and
   re-tune these tokens (see @rempeyek/theme-engine → themes.css).
   Every accent in the app flows from --acc via color-mix().
   Typography: Orbitron (hero display, falls back to Bahnschrift offline) · Cascadia Mono (data) */
/* Self-hosted display faces (latin subsets, apps/web/public/fonts/, OFL licensed).
   Orbitron + JetBrains Mono ship as variable fonts; Rajdhani as two static weights. */
@font-face {
  font-family: "Orbitron"; font-style: normal; font-weight: 400 900; font-display: swap;
  src: url("/fonts/orbitron-var.woff2") format("woff2");
}
@font-face {
  font-family: "Rajdhani"; font-style: normal; font-weight: 400; font-display: swap;
  src: url("/fonts/rajdhani-400.woff2") format("woff2");
}
@font-face {
  font-family: "Rajdhani"; font-style: normal; font-weight: 600; font-display: swap;
  src: url("/fonts/rajdhani-600.woff2") format("woff2");
}
@font-face {
  font-family: "JetBrains Mono"; font-style: normal; font-weight: 100 800; font-display: swap;
  src: url("/fonts/jetbrains-mono-var.woff2") format("woff2");
}

:root {
  --bg: #050310;
  --panel: #0C0920;
  --card: #131031;
  --card-hi: #1A1642;
  --line: #241E4E;
  --text: #EEEBFF;
  --muted: #8E88BE;
  --cyan: #00E5FF;
  --magenta: #FF3DD8;
  --lime: #A6FF3C;
  --amber: #FFB01F;
  --violet: #8C5BFF;
  --red: #FF4D6A;
  --mono: "Cascadia Mono", "Cascadia Code", Consolas, monospace;
  --disp: Bahnschrift, "Segoe UI Semibold", "Segoe UI", sans-serif;
  --hero: Bahnschrift, "Segoe UI Variable Display", "Segoe UI Semibold", sans-serif;
  --acc: #00E5FF; /* active accent — themes override this + the palette below */
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }
body {
  background: var(--bg);
  color: var(--text);
  font: 13.5px/1.5 "Segoe UI", system-ui, sans-serif;
  overflow: hidden;
}
.skip-link { position: fixed; z-index: 1000; top: 8px; left: 8px; padding: 8px 12px; background: var(--text); color: var(--bg); transform: translateY(-150%); }
.skip-link:focus { transform: translateY(0); }
.app-state { width: min(620px, 100%); margin: 10vh auto; padding: 28px; border: 1px solid var(--line); border-radius: var(--surface-radius, 10px); background: var(--panel); }
.app-state .skeleton-block { height: 7px; margin-bottom: 24px; }
.app-state h1 { font: 700 24px var(--disp); margin-bottom: 8px; }
.app-state p { color: var(--muted); margin-bottom: 18px; }

/* background: grid + glow, static, does not capture the pointer */
.bg-grid, .bg-glow { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
/* vortex flow-field canvas — mounted by React between the glow layers and the shell */
.bg-vortex { position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: .5; }
.bg-grid {
  background:
    linear-gradient(rgba(140, 91, 255, .05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(140, 91, 255, .05) 1px, transparent 1px);
  background-size: 42px 42px;
  mask-image: radial-gradient(ellipse 90% 80% at 60% 10%, #000 0%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 90% 80% at 60% 10%, #000 0%, transparent 75%);
}
.bg-glow {
  background:
    radial-gradient(700px 360px at 85% -5%, color-mix(in srgb, var(--acc) 12%, transparent), transparent 65%),
    radial-gradient(600px 400px at -5% 100%, rgba(255, 61, 216, .10), transparent 65%);
}
/* drifting nebula plasma — two soft clouds slowly orbiting behind everything */
.bg-glow::before {
  content: ""; position: absolute; inset: -20%;
  background:
    radial-gradient(38% 30% at 30% 35%, rgba(140, 91, 255, .13), transparent 70%),
    radial-gradient(30% 26% at 72% 62%, color-mix(in srgb, var(--acc) 10%, transparent), transparent 70%),
    radial-gradient(24% 20% at 55% 25%, rgba(255, 61, 216, .07), transparent 70%);
}
/* star twinkle layer */
.bg-glow::after {
  content: ""; position: absolute; inset: 0;
  background:
    radial-gradient(1.5px 1.5px at 12% 18%, rgba(238, 235, 255, .8), transparent 100%),
    radial-gradient(1px 1px at 27% 66%, rgba(238, 235, 255, .55), transparent 100%),
    radial-gradient(2px 2px at 41% 32%, color-mix(in srgb, var(--acc) 6%, transparent), transparent 100%),
    radial-gradient(1px 1px at 58% 78%, rgba(238, 235, 255, .5), transparent 100%),
    radial-gradient(1.5px 1.5px at 69% 12%, rgba(140, 91, 255, .7), transparent 100%),
    radial-gradient(1px 1px at 81% 46%, rgba(238, 235, 255, .55), transparent 100%),
    radial-gradient(2px 2px at 91% 82%, rgba(255, 61, 216, .5), transparent 100%),
    radial-gradient(1px 1px at 6% 90%, rgba(238, 235, 255, .45), transparent 100%),
    radial-gradient(1px 1px at 48% 55%, rgba(238, 235, 255, .4), transparent 100%);
}
@media (prefers-reduced-motion: no-preference) {
  .bg-glow::before { animation: nebulaDrift 90s ease-in-out infinite alternate; }
  .bg-glow::after { animation: twinkle 5.5s ease-in-out infinite alternate; }
  @keyframes nebulaDrift {
    from { transform: translate(-2%, -1%) rotate(0deg) scale(1); }
    to   { transform: translate(2%, 2%) rotate(4deg) scale(1.06); }
  }
  @keyframes twinkle { from { opacity: .45; } to { opacity: 1; } }
}

.shell { position: relative; z-index: 1; display: flex; height: 100vh; }

/* ---------------- sidebar ---------------- */
.sidebar {
  width: 232px; flex-shrink: 0; display: flex; flex-direction: column;
  background: linear-gradient(180deg, var(--panel), #080617);
  border-right: 1px solid var(--line); padding: 18px 14px;
}
.brand { display: flex; gap: 10px; align-items: center; padding: 2px 6px 18px; }
.brand-mark {
  width: 38px; height: 38px; display: grid; place-items: center; font-size: 19px;
  color: var(--acc); border: 1px solid var(--acc);
  box-shadow: 0 0 14px color-mix(in srgb, var(--acc) 45%, transparent), inset 0 0 10px color-mix(in srgb, var(--acc) 18%, transparent);
  clip-path: polygon(50% 0, 100% 25%, 100% 75%, 50% 100%, 0 75%, 0 25%);
}
.brand-name { font-family: var(--disp); font-size: 16.5px; letter-spacing: .12em; }
.brand-slash { color: var(--magenta); text-shadow: 0 0 8px var(--magenta); }
.brand-sub { font-family: var(--mono); font-size: 9.5px; color: var(--muted); letter-spacing: .18em; text-transform: uppercase; }

#nav { display: flex; flex-direction: column; gap: 3px; }
.nav-item {
  display: flex; align-items: center; gap: 10px; width: 100%; text-align: left;
  background: none; border: 1px solid transparent; border-left: 2px solid transparent;
  color: var(--muted); font: 600 12.5px var(--disp); letter-spacing: .08em;
  padding: 9px 10px; cursor: pointer; border-radius: 0 8px 8px 0; transition: all .15s;
}
.nav-ico { width: 16px; text-align: center; }
.nav-item:hover { color: var(--text); background: rgba(140, 91, 255, .08); }
.nav-item.active {
  color: var(--acc); border-left-color: var(--acc);
  background: linear-gradient(90deg, color-mix(in srgb, var(--acc) 12%, transparent), transparent 80%);
  text-shadow: 0 0 10px color-mix(in srgb, var(--acc) 6%, transparent);
}
.nav-item span { text-transform: var(--heading-case, uppercase); }
.nav-chevron { margin-left: auto; flex: 0 0 auto; }
.brand-logo {
  width: 38px; height: 38px; flex: 0 0 auto; object-fit: cover; border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--acc) 35%, transparent);
  background: color-mix(in srgb, var(--acc) 13%, transparent);
  box-shadow: 0 0 18px color-mix(in srgb, var(--acc) 20%, transparent);
}
/* Settings pinned to the sidebar bottom, above the system-health footer */
.side-settings { margin-top: auto; padding-top: 6px; border-top: 1px solid var(--line); }
.sidebar .side-settings + .side-foot { margin-top: 12px; }
.side-health { display: flex; flex-direction: column; gap: 5px; padding-bottom: 8px; }
.side-health-label { font-family: var(--mono); font-size: 7.5px; letter-spacing: .1em; color: var(--muted); }
.side-health-row { display: flex; align-items: center; gap: 8px; }
.side-health-bar { flex: 1; height: 3px; border-radius: 999px; overflow: hidden; background: color-mix(in srgb, var(--acc) 10%, transparent); }
.side-health-bar i { display: block; height: 100%; border-radius: 999px; background: linear-gradient(to right, var(--acc), var(--lime)); transition: width .5s ease; }
.side-health-row b { font: 700 10px var(--font-heading, var(--disp)); color: var(--lime); }
.side-health-note { font-family: var(--mono); font-size: 7px; letter-spacing: .05em; color: color-mix(in srgb, var(--acc) 40%, var(--muted)); }
.side-health-note.is-warn { color: var(--red); }

.side-label { font-family: var(--mono); font-size: 9.5px; color: var(--muted); letter-spacing: .22em; margin: 20px 8px 8px; }
.side-agents { display: flex; flex-direction: column; gap: 4px; overflow-y: auto; }
.side-agent {
  display: flex; gap: 9px; align-items: center; padding: 6px 8px;
  border-radius: 8px; font-size: 11.5px; color: var(--muted); cursor: pointer;
}
.side-agent { width: 100%; border: 0; background: transparent; color: inherit; text-align: left; font: inherit; }
.side-agent:focus-visible { outline: 2px solid var(--acc); outline-offset: 2px; }
.side-agent:hover { background: color-mix(in srgb, var(--acc) 7%, transparent); color: var(--text); }
.side-agent b { color: var(--text); font-weight: 600; }
.side-avatar { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
.side-foot {
  margin-top: auto; padding: 12px 8px 0; border-top: 1px solid var(--line);
  font-family: var(--mono); font-size: 9.5px; color: var(--muted);
  display: flex; flex-direction: column; gap: 3px;
}
.side-foot span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.side-vault { color: var(--acc); text-decoration: none; letter-spacing: .04em; padding: 2px 0; }
.side-vault:hover { text-shadow: 0 0 8px var(--acc); }

/* ---------------- main ---------------- */
.main { flex: 1; overflow-y: auto; padding: 26px 30px 60px; }
.view { display: none; }
.view.active { display: block; }
.view-flush.active { display: flex; flex-direction: column; height: calc(100vh - 52px); }

.page-head { margin-bottom: 20px; }
.page-head h1 {
  font-family: var(--disp); font-size: 24px; letter-spacing: .18em; font-weight: 700;
  background: linear-gradient(90deg, var(--text) 60%, var(--acc));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
}
.page-meta { color: var(--muted); font-size: 12px; margin-top: 4px; }
.page-meta code { font-family: var(--mono); font-size: 11px; color: var(--acc); }

/* stat tiles */
.tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 14px; margin-bottom: 26px; }
.tile {
  background: linear-gradient(160deg, var(--card), var(--panel));
  border: 1px solid var(--line); border-radius: 10px; padding: 14px 16px;
  position: relative; overflow: hidden;
}
.tile::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--tile-c, var(--acc)), transparent);
}
.tile-top { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; letter-spacing: .1em; color: var(--muted); text-transform: uppercase; }
.tile-val { font-family: var(--disp); font-size: 32px; font-weight: 700; margin: 6px 0 2px; color: var(--tile-c, var(--acc)); text-shadow: 0 0 16px color-mix(in srgb, var(--tile-c, var(--acc)) 55%, transparent); }
.tile-sub { font-size: 11px; color: var(--muted); }

.section-row { display: flex; justify-content: space-between; align-items: center; margin: 6px 0 12px; }
.section-label { font-family: var(--mono); font-size: 10px; letter-spacing: .22em; color: var(--muted); }

/* ---------------- agent cards ---------------- */
.agent-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(215px, 1fr)); gap: 14px; margin-bottom: 26px; }
.agent-row-wide { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
.agent-card {
  background: linear-gradient(165deg, var(--card), var(--panel));
  border: 1px solid var(--line); border-radius: 12px; padding: 14px;
  cursor: pointer; transition: transform .15s, border-color .15s, box-shadow .15s;
  position: relative;
}
.agent-card:hover { transform: translateY(-2px); border-color: var(--ac, var(--acc)); box-shadow: 0 0 22px color-mix(in srgb, var(--ac, var(--acc)) 22%, transparent); }
.agent-card.selected { border-color: var(--ac, var(--acc)); box-shadow: 0 0 22px color-mix(in srgb, var(--ac, var(--acc)) 30%, transparent); }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.avatar {
  width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center;
  font-size: 21px; background: var(--card-hi); position: relative; flex-shrink: 0;
  border: 2px solid var(--ac, var(--line));
  box-shadow: 0 0 12px color-mix(in srgb, var(--ac, var(--acc)) 40%, transparent);
}
.avatar img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
.avatar-lg { width: 84px; height: 84px; font-size: 38px; }
.avatar-edit {
  position: absolute; right: -4px; bottom: -4px; width: 26px; height: 26px;
  border-radius: 50%; border: 1px solid var(--line); background: var(--card-hi);
  color: var(--acc); font-size: 12px; cursor: pointer; display: grid; place-items: center;
}
.avatar-edit:hover { border-color: var(--acc); box-shadow: 0 0 10px color-mix(in srgb, var(--acc) 5%, transparent); }
.agent-name { font-family: var(--disp); font-size: 15.5px; font-weight: 700; letter-spacing: .04em; }
.agent-role { font-size: 11.5px; color: var(--muted); margin: 2px 0 10px; }
.pill-row { display: flex; flex-wrap: wrap; gap: 6px; }
.pill {
  display: inline-flex; align-items: center; gap: 6px; padding: 3px 9px;
  border: 1px solid var(--line); border-radius: 999px;
  font-family: var(--mono); font-size: 9.5px; letter-spacing: .06em;
  background: rgba(5, 3, 16, .5);
}
.dot { width: 7px; height: 7px; border-radius: 50%; }
.dot.working { background: var(--lime); box-shadow: 0 0 8px var(--lime); }
.dot.waiting { background: var(--amber); box-shadow: 0 0 8px var(--amber); }
.dot.idle { background: #4A4470; }
.dot.running { background: var(--cyan); box-shadow: 0 0 8px var(--acc); }
.dot.error, .dot.exited { background: var(--red); box-shadow: 0 0 8px var(--red); }
.lbl-working { color: var(--lime); } .lbl-waiting { color: var(--amber); }
.lbl-idle { color: var(--muted); } .lbl-running { color: var(--cyan); }
.lbl-error, .lbl-exited { color: var(--red); }
.gw-why { color: var(--muted); max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-btns { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.card-btns .btn { padding: 5px 10px; font-size: 10px; }
.gw-ctl { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
.gw-note { font-size: 11px; color: var(--muted); border-left: 2px solid var(--amber); padding: 6px 10px; margin-bottom: 10px; background: rgba(255,176,31,.05); border-radius: 0 6px 6px 0; }
.muted { color: var(--muted); font-size: 11.5px; }
@media (prefers-reduced-motion: no-preference) {
  .dot.working, .dot.running { animation: pulse 2.2s ease-in-out infinite; }
  @keyframes pulse { 50% { opacity: .45; } }
}

/* buttons */
.btn {
  font: 700 11px var(--disp); letter-spacing: .1em; padding: 7px 14px;
  border-radius: 7px; border: 1px solid var(--line); background: var(--card-hi);
  color: var(--text); cursor: pointer; transition: all .15s; text-transform: uppercase;
}
.btn:disabled { opacity: .45; cursor: not-allowed; }
.btn-primary { border-color: var(--acc); color: var(--acc); background: color-mix(in srgb, var(--acc) 8%, transparent); }
.btn-primary:hover:not(:disabled) { background: color-mix(in srgb, var(--acc) 18%, transparent); box-shadow: 0 0 16px color-mix(in srgb, var(--acc) 4%, transparent); }
.btn-run { border-color: var(--lime); color: var(--lime); background: rgba(166, 255, 60, .07); }
.btn-run:hover:not(:disabled) { background: rgba(166, 255, 60, .16); box-shadow: 0 0 14px rgba(166, 255, 60, .35); }
.btn-stop { border-color: var(--red); color: var(--red); background: rgba(255, 77, 106, .07); }
.btn-stop:hover:not(:disabled) { background: rgba(255, 77, 106, .16); box-shadow: 0 0 14px rgba(255, 77, 106, .35); }
.btn-dim { color: var(--muted); }
.btn-dim:hover:not(:disabled) { color: var(--text); border-color: var(--violet); }

/* split Start button + dropdown terminal */
.gw-split { position: relative; display: inline-flex; }
.gw-split .gw-main { border-top-right-radius: 0; border-bottom-right-radius: 0; }
.gw-split .gw-caret { border-top-left-radius: 0; border-bottom-left-radius: 0; border-left-color: rgba(5,3,16,.5); padding: 5px 7px; }
.gw-menu {
  position: absolute; top: calc(100% + 6px); right: 0; z-index: 50; display: none;
  min-width: 234px; flex-direction: column; padding: 6px; text-align: left;
  background: linear-gradient(170deg, var(--card), var(--panel));
  border: 1px solid var(--line); border-radius: 10px; box-shadow: 0 14px 34px rgba(0,0,0,.6);
}
.gw-menu.open { display: flex; }
.gw-menu button {
  text-align: left; font: 600 11px var(--disp); letter-spacing: .03em; text-transform: none;
  padding: 8px 10px; border: 0; border-radius: 7px; background: transparent; color: var(--text);
  cursor: pointer; white-space: nowrap; width: 100%;
}
.gw-menu button:hover { background: rgba(0,229,255,.1); color: var(--acc); }
.gw-menu-sep { height: 1px; background: var(--line); margin: 5px 4px; }

/* overlay login token */
.token-ov { position: fixed; inset: 0; z-index: 200; display: grid; place-items: center;
  background: rgba(5,3,16,.82); backdrop-filter: blur(4px); }
.token-ov[hidden] { display: none; }
.token-box { width: min(360px, 90vw); display: flex; flex-direction: column; gap: 12px;
  padding: 26px 24px; border: 1px solid var(--acc); border-radius: 14px;
  background: linear-gradient(170deg, var(--card), var(--panel));
  box-shadow: 0 0 40px rgba(0,229,255,.25); }
.token-title { font-family: var(--disp); font-size: 17px; letter-spacing: .1em; color: var(--acc); }
.token-sub { font-size: 12px; color: var(--muted); }
.token-box input { padding: 10px 12px; border-radius: 8px; border: 1px solid var(--line);
  background: var(--bg); color: var(--text); font: 13px var(--mono); }
.token-box input:focus { outline: none; border-color: var(--acc); }
.token-hint { font-size: 11px; color: var(--red); min-height: 14px; }

/* panels, lists */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.panel { background: linear-gradient(170deg, var(--card), var(--panel)); border: 1px solid var(--line); border-radius: 12px; padding: 16px; }
.panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.panel-head h2 { font-family: var(--disp); font-size: 12.5px; letter-spacing: .16em; color: var(--text); }
.chip { font-family: var(--mono); font-size: 10px; padding: 3px 9px; border-radius: 999px; border: 1px solid var(--magenta); color: var(--magenta); }
.chip-plain { border-color: var(--line); color: var(--muted); }
/* R#5: send-task-to-agent form */
.task-form { display: flex; gap: 6px; margin-bottom: 10px; }
.task-form select, .task-form input {
  font-family: var(--mono); font-size: 11px; color: var(--text);
  background: rgba(255, 255, 255, .03); border: 1px solid var(--line);
  border-radius: 7px; padding: 6px 8px; outline: none;
}
.task-form select { flex: 0 0 auto; max-width: 130px; }
.task-form input { flex: 1 1 auto; min-width: 0; }
.task-form input:focus, .task-form select:focus { border-color: var(--lime); }
.task-form .btn { flex: 0 0 auto; padding: 6px 10px; font-size: 11px; }

/* R#11 config banner */
.config-banner { margin: 0 0 12px; padding: 10px 14px; border-radius: 8px; font-size: 12px; color: #ffd; font-family: var(--mono);
  background: rgba(255, 176, 31, .1); border: 1px solid rgba(255, 176, 31, .5); }
.config-banner code { color: var(--red); }

/* Bonus: mini button + review action row */
.review-act { display: flex; align-items: center; gap: 8px; }
.btn-mini { padding: 4px 8px; font-size: 10px; }

/* R#9 vault health + R#8 schedule */
.vault-health, .sched-list { display: flex; flex-direction: column; gap: 8px; }
.vh-row, .sched-row { display: flex; align-items: center; gap: 9px; font-size: 12px; }
.vh-k { color: var(--muted); min-width: 130px; }
.vh-v { color: var(--text); font-family: var(--mono); margin-left: auto; }
.vh-hint { font-size: 10px; color: var(--muted); font-family: var(--mono); opacity: .7; margin-top: 2px; }
.sched-a { color: var(--text); min-width: 96px; }
.sched-d { color: var(--muted); font-family: var(--mono); font-size: 10.5px; }

.review-list, .list-panel { display: flex; flex-direction: column; gap: 8px; }
.review-item, .list-item {
  display: flex; justify-content: space-between; align-items: center; gap: 12px;
  padding: 10px 12px; border: 1px solid var(--line); border-radius: 9px;
  background: rgba(5, 3, 16, .45);
}
.review-item .t, .list-item b { font-size: 12.5px; font-weight: 600; }
.review-item .m, .list-item .p { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 2px; }
.review-item a, .list-item a { color: var(--acc); font-size: 11px; text-decoration: none; white-space: nowrap; }
.review-item a:hover, .list-item a:hover { text-shadow: 0 0 8px var(--acc); }
.list-item .d { font-family: var(--mono); font-size: 10px; color: var(--muted); }
.kind { font-family: var(--mono); font-size: 9px; padding: 1px 7px; border-radius: 999px; margin-left: 8px; }
.kind.inbox { border: 1px solid var(--amber); color: var(--amber); }
.kind.task { border: 1px solid var(--violet); color: var(--violet); }
.empty { color: var(--muted); font-size: 12px; padding: 14px; border: 1px dashed var(--line); border-radius: 9px; }
.workflow-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.wf { border: 1px solid var(--line); border-left: 2px solid var(--ac, var(--magenta)); border-radius: 9px; padding: 11px 12px; background: rgba(5, 3, 16, .45); transition: border-color .15s, box-shadow .15s; }
.wf:hover { box-shadow: 0 0 16px color-mix(in srgb, var(--ac, var(--magenta)) 20%, transparent); }
.wf .who { font-family: var(--mono); font-size: 9.5px; color: var(--magenta); letter-spacing: .12em; text-transform: uppercase; }
.wf .t { font-weight: 700; font-size: 12.5px; margin: 3px 0 2px; }
.wf .d { font-size: 11px; color: var(--muted); }

/* ---------------- agent detail ---------------- */
.detail {
  border: 1px solid var(--line); border-radius: 14px; overflow: hidden;
  background: linear-gradient(170deg, var(--card), var(--panel));
  box-shadow: 0 0 30px color-mix(in srgb, var(--ac, var(--acc)) 12%, transparent);
}
.detail-head {
  display: flex; gap: 18px; align-items: center; padding: 18px 20px;
  border-bottom: 1px solid var(--line);
  background: linear-gradient(90deg, color-mix(in srgb, var(--ac, var(--acc)) 9%, transparent), transparent 70%);
}
.detail-head h2 { font-family: var(--disp); font-size: 20px; letter-spacing: .08em; }
.detail-meta { font-family: var(--mono); font-size: 10.5px; color: var(--muted); margin-top: 3px; }
.detail-actions { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding: 16px 20px 20px; }
.dsec { border: 1px solid var(--line); border-radius: 10px; padding: 12px 14px; background: rgba(5, 3, 16, .4); min-width: 0; display: flex; flex-direction: column; }
.dsec h3 { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; color: var(--muted); margin-bottom: 10px; text-transform: uppercase; flex: 0 0 auto; }
/* fixed-height scroll frame: sections (Telemetry, Sessions, Subagents, Vault lane) stay a fixed size and scroll internally instead of growing the whole panel */
.dsec-body { flex: 1 1 auto; min-height: 148px; max-height: 260px; overflow-y: auto; padding-right: 4px; }
.dsec-body::-webkit-scrollbar { width: 7px; }
.dsec-body .empty { min-height: 0; }
.dsec h3 .cnt { color: var(--ac, var(--acc)); }
.sess { padding: 8px 10px; border-left: 2px solid var(--ac, var(--acc)); background: rgba(255,255,255,.02); border-radius: 0 7px 7px 0; margin-bottom: 8px; }
.sess .top { display: flex; justify-content: space-between; gap: 8px; font-family: var(--mono); font-size: 10px; color: var(--muted); }
.sess .prm { font-size: 11.5px; margin: 4px 0 2px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.sess .act { font-family: var(--mono); font-size: 10px; color: var(--acc); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.subrow { display: flex; align-items: center; gap: 9px; padding: 7px 9px; border-bottom: 1px solid rgba(36, 30, 78, .6); font-size: 11.5px; }
.subrow:last-child { border-bottom: none; }
.subrow .ty { font-family: var(--mono); font-size: 9px; padding: 1px 7px; border-radius: 999px; border: 1px solid var(--violet); color: var(--violet); white-space: nowrap; }
.subrow .nm { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.subrow .st { font-family: var(--mono); font-size: 9.5px; }
.st-done { color: var(--lime); } .st-running { color: var(--amber); }
.tele-bar { height: 5px; border-radius: 999px; background: rgba(255,255,255,.07); margin-top: 5px; overflow: hidden; }
.tele-bar i { display: block; height: 100%; background: linear-gradient(90deg, var(--acc), var(--magenta)); box-shadow: 0 0 8px var(--acc); }
.logpane {
  background: #030209; border: 1px solid var(--line); border-radius: 8px;
  font: 10.5px/1.65 var(--mono); color: #9BE8FF; padding: 10px 12px;
  height: 220px; overflow-y: auto; white-space: pre-wrap; word-break: break-all;
}
.mini-list { display: flex; flex-direction: column; gap: 5px; font-size: 11px; }
.mini-list a { color: var(--text); text-decoration: none; display: flex; justify-content: space-between; gap: 10px; }
.mini-list a:hover { color: var(--acc); }
.mini-list .d { font-family: var(--mono); font-size: 9.5px; color: var(--muted); white-space: nowrap; }

/* ---------------- Neural Vault Cosmos v2 ---------------- */
.neural-vault-v2 { display: flex; flex-direction: column; min-height: 0; height: 100%; gap: 10px; }
.graph-bar {
  display: grid; grid-template-columns: minmax(150px, .8fr) minmax(190px, 1.15fr) auto auto auto;
  align-items: center; gap: 10px; padding: 10px;
  border: 1px solid var(--line); border-radius: var(--surface-radius, 12px);
  background: color-mix(in srgb, var(--panel) 84%, transparent);
}
.graph-heading { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.graph-title { font-family: var(--disp); font-size: 18px; letter-spacing: .18em; }
.graph-counts, .graph-stats { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: .05em; }
.graph-search {
  background: color-mix(in srgb, var(--bg) 72%, transparent); border: 1px solid var(--line); border-radius: 8px;
  color: var(--text); font: 12px var(--mono); padding: 9px 12px; width: 100%; min-width: 0; outline: none;
}
.graph-search:focus { border-color: var(--acc); box-shadow: 0 0 12px color-mix(in srgb, var(--acc) 3%, transparent); }
.graph-open {
  font: 700 11px var(--disp); letter-spacing: .1em; text-decoration: none; text-transform: uppercase;
  color: var(--acc); border: 1px solid var(--acc); border-radius: 7px; padding: 7px 12px;
  background: color-mix(in srgb, var(--acc) 8%, transparent); transition: all .15s;
}
.graph-open:hover { background: color-mix(in srgb, var(--acc) 18%, transparent); box-shadow: 0 0 16px color-mix(in srgb, var(--acc) 4%, transparent); }
.graph-legend { display: flex; gap: 10px; flex-wrap: wrap; margin-left: auto; }
.leg { display: inline-flex; align-items: center; gap: 5px; font-family: var(--mono); font-size: 9.5px; color: var(--muted); }
.leg i { width: 9px; height: 9px; border-radius: 50%; box-shadow: 0 0 6px currentColor; }
.graph-workspace { display: grid; grid-template-columns: minmax(0, 1fr) minmax(220px, 280px); gap: 10px; flex: 1; min-height: 0; }
.graph-stage { display: flex; flex-direction: column; min-width: 0; min-height: 0; gap: 8px; }
.graph-wrap {
  position: relative; flex: 1; min-height: 420px; border: 1px solid var(--line); border-radius: 14px; overflow: hidden;
  background:
    radial-gradient(ellipse at center, rgba(10, 7, 34, .55) 0%, rgba(5, 3, 16, .88) 75%), #050310;
}
.graph-layers, .graph-modes {
  display: inline-flex; align-items: center; gap: 6px; min-width: 0; padding: 4px;
  border: 1px solid color-mix(in srgb, var(--line) 75%, transparent); border-radius: 999px;
  background: color-mix(in srgb, var(--bg) 35%, transparent);
}
.graph-modes { flex-wrap: wrap; }
.graph-error, .graph-focus-bar {
  display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 9px 12px;
  border: 1px solid var(--line); border-radius: 8px; background: var(--panel); font: 11px var(--mono);
}
.graph-error { border-color: color-mix(in srgb, var(--red) 50%, var(--line)); color: var(--red); }
.graph-focus-bar { color: var(--acc); }
.graph-focus-bar button { min-height: 32px; color: inherit; background: transparent; border: 1px solid currentColor; border-radius: 6px; cursor: pointer; }
.graph-inspector {
  min-width: 0; overflow: auto; padding: 16px; border: 1px solid var(--line); border-radius: var(--surface-radius, 12px);
  background: color-mix(in srgb, var(--panel) 90%, transparent);
}
.graph-inspector-label { color: var(--acc); font: 700 10px var(--mono); letter-spacing: .16em; }
.graph-inspector h2 { margin: 14px 0; overflow-wrap: anywhere; font: 600 20px/1.25 var(--disp); }
.graph-inspector p { color: var(--muted); font-size: 12px; line-height: 1.6; }
.graph-inspector dl { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 0; }
.graph-inspector dl div { min-width: 0; }
.graph-inspector dl .wide { grid-column: 1 / -1; }
.graph-inspector dt { color: var(--muted); font: 9px var(--mono); letter-spacing: .1em; text-transform: uppercase; }
.graph-inspector dd { margin: 3px 0 0; overflow-wrap: anywhere; font: 11px/1.45 var(--mono); }
.graph-inspector-actions { display: flex; flex-direction: column; gap: 8px; margin-top: 18px; }
.graph-inspector-actions .btn { min-height: 40px; }
.graph-breadcrumbs { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 10px; color: var(--muted); font: 9px var(--mono); }
.graph-breadcrumbs span:not(:last-child)::after { content: " /"; color: var(--line); }
.graph-semantic-legend { display: flex; flex-wrap: wrap; gap: 8px 16px; color: var(--muted); font: 9px var(--mono); }
.graph-semantic-legend span { display: inline-flex; align-items: center; gap: 6px; }
.graph-semantic-legend i { display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: var(--graph-note); }
.graph-semantic-legend .legend-recent { box-shadow: 0 0 10px var(--graph-note); }
.graph-semantic-legend .legend-ghost { opacity: .45; border: 1px dashed var(--graph-ghost); background: transparent; }
.graph-semantic-legend .legend-change { border: 1px dashed var(--acc); background: transparent; }
.graph-table-wrap { max-height: 38vh; overflow: auto; border: 1px solid var(--line); border-radius: var(--surface-radius, 12px); background: var(--panel); }
.graph-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.graph-table caption { padding: 10px; text-align: left; color: var(--muted); }
.graph-table th, .graph-table td { padding: 8px 12px; text-align: left; border-top: 1px solid var(--line); }
.graph-table thead th { position: sticky; top: 0; z-index: 1; background: var(--panel); color: var(--acc); }
.graph-table tr.selected { background: color-mix(in srgb, var(--acc) 10%, transparent); }
.graph-table-node { color: var(--text); background: none; border: 0; padding: 0; text-align: left; cursor: pointer; font: inherit; }
.graph-table-node:hover, .graph-table-node:focus-visible, .graph-table a { color: var(--acc); }
.lyr {
  font-family: var(--mono); font-size: 9.5px; letter-spacing: .1em; cursor: pointer;
  min-height: 32px; padding: 4px 10px; border-radius: 999px; border: 1px solid var(--line);
  background: transparent; color: var(--muted); transition: all .15s;
}
.lyr:hover { border-color: color-mix(in srgb, var(--acc) 40%, var(--line)); color: var(--text); }
.lyr.on {
  color: var(--text); border-color: color-mix(in srgb, var(--acc) 55%, var(--line));
  background: color-mix(in srgb, var(--acc) 14%, transparent); box-shadow: 0 0 10px color-mix(in srgb, var(--acc) 18%, transparent);
}
#graphCanvas { width: 100%; height: 100%; display: block; cursor: grab; }
#graphCanvas.grabbing { cursor: grabbing; }
#graphCanvas:focus-visible { outline: 2px solid var(--acc); outline-offset: -3px; }
.graph-hint {
  position: absolute; bottom: 10px; left: 12px; pointer-events: none;
  font-family: var(--mono); font-size: 9.5px; color: var(--muted); opacity: .8;
}

/* ---------------- reports ---------------- */
.report-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 14px; }
.rep-wide { grid-column: 1 / -1; }
.rep-svg { width: 100%; height: auto; display: block; }
.rep-table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
.rep-table th { font-family: var(--mono); font-size: 9.5px; letter-spacing: .12em; color: var(--muted); text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--line); text-transform: uppercase; }
.rep-table td { padding: 7px 8px; border-bottom: 1px solid rgba(36, 30, 78, .5); }
.rep-bar { height: 6px; border-radius: 999px; background: rgba(255,255,255,.06); overflow: hidden; min-width: 70px; }
.rep-bar i { display: block; height: 100%; background: linear-gradient(90deg, var(--magenta), var(--violet)); box-shadow: 0 0 8px var(--magenta); }
.rep-head-stats { display: flex; gap: 26px; flex-wrap: wrap; }
.rep-stat .v { font-family: var(--disp); font-size: 26px; font-weight: 700; color: var(--acc); text-shadow: 0 0 14px rgba(0,229,255,.5); }
.rep-stat .l { font-family: var(--mono); font-size: 9.5px; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; }

/* ---------------- evidence table (Agent Map accessible fallback) ---------------- */
.topo-fallback { margin:10px 14px 0; position:relative; border:1px solid var(--line); border-radius:var(--control-radius,7px); background:var(--surface-fill); }
.topo-fallback summary { cursor:pointer; padding:10px 12px; color:var(--text); font:10px var(--mono); }
.topo-table-scroll { overflow-x:auto; border-top:1px solid var(--line); }
.topo-fallback table { width:100%; border-collapse:collapse; min-width:720px; font-size:10px; }
.topo-fallback caption { position:absolute; width:1px; height:1px; overflow:hidden; clip-path:inset(50%); }
.topo-fallback th,.topo-fallback td { padding:8px 9px; text-align:left; border-bottom:1px solid var(--line); color:var(--text); }
.topo-fallback th { color:var(--muted); font:8px var(--mono); text-transform:uppercase; letter-spacing:.1em; }
.topo-fallback td { font:10px/1.4 var(--mono); }
.topo-fallback button { border:1px solid var(--line); background:transparent; color:var(--text); padding:6px 8px; cursor:pointer; font:9px var(--mono); }

/* stacked page sections (Protocols, Observatory, Settings) */
.view-stack { display: grid; gap: 14px; }

/* settings page */
.settings-themes .theme-pick { grid-template-columns: repeat(4, minmax(120px, 1fr)); gap: 12px; padding: 0; }
.settings-themes .theme-sw { min-height: 84px; }
.settings-themes .theme-sw-label { padding-top: 52px; font-size: 9px; }
.settings-themes .side-label { margin: 0 0 8px; }
.settings-note { margin: 12px 0 0; color: var(--muted); font-size: 11.5px; line-height: 1.55; }
.settings-note code { font-family: var(--font-data, var(--mono)); font-size: 10px; color: var(--acc); }
.settings-facts { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; }
.settings-facts > div { display: grid; gap: 3px; min-width: 0; }
.settings-facts span { font: 8.5px var(--font-data, var(--mono)); letter-spacing: .12em; color: var(--muted); }
.settings-facts b { font-size: 12px; font-weight: 600; overflow-wrap: anywhere; }
.settings-facts a { color: var(--acc); text-decoration: none; }
.settings-facts a:hover { text-decoration: underline; }
@media (max-width: 860px) { .settings-themes .theme-pick { grid-template-columns: 1fr 1fr; } }

/* ---------------- skeleton loaders ---------------- */
.skeleton-block {
  height: 58px; border-radius: 9px;
  background: linear-gradient(100deg, var(--card) 40%, var(--card-hi) 50%, var(--card) 60%);
  background-size: 200% 100%;
}
@media (prefers-reduced-motion: no-preference) {
  .skeleton-block { animation: shimmer 1.4s linear infinite; }
  @keyframes shimmer { to { background-position: -200% 0; } }
}

/* ---------------- micro-interactions & focus ---------------- */
.btn:active:not(:disabled) { transform: translateY(1px); }
.btn:focus-visible, .nav-item:focus-visible, input:focus-visible, select:focus-visible {
  outline: 2px solid var(--acc); outline-offset: 2px;
}
.view.active { animation: viewIn .18s ease-out; }
@media (prefers-reduced-motion: reduce) { .view.active { animation: none; } }
@keyframes viewIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

/* custom scrollbars (WebKit + Firefox) */
* { scrollbar-width: thin; scrollbar-color: var(--line) transparent; }
*::-webkit-scrollbar { width: 9px; height: 9px; }
*::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; border: 2px solid var(--bg); }
*::-webkit-scrollbar-thumb:hover { background: var(--violet); }
*::-webkit-scrollbar-track { background: transparent; }

/* ---------------- COSMOS theme layer (overrides — keep last) ---------------- */
/* hero typography: Orbitron carries the cosmos identity on big display text only;
   small UI stays Bahnschrift so nothing wraps or crowds */
.page-head h1 {
  font-family: var(--hero); font-weight: 900; font-size: 22px;
  background: linear-gradient(90deg, var(--acc), var(--violet) 55%, var(--magenta));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 14px color-mix(in srgb, var(--acc) 35%, transparent));
}
.brand-name { font-family: var(--hero); font-weight: 700; font-size: 13.5px; }
.graph-title {
  font-family: var(--hero); font-weight: 700; font-size: 15px;
  background: linear-gradient(90deg, var(--acc), var(--violet));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 10px color-mix(in srgb, var(--acc) 4%, transparent));
}
.tile-val { font-family: var(--hero); font-weight: 700; font-size: 26px; }
.rep-stat .v { font-family: var(--hero); font-size: 22px; }
.section-label { color: color-mix(in srgb, var(--violet) 42%, var(--muted)); text-shadow: 0 0 12px color-mix(in srgb, var(--violet) 50%, transparent); }

/* glass panels: translucent over the living cosmos backdrop */
.panel, .tile, .agent-card {
  background: linear-gradient(165deg, rgba(19, 16, 49, .68), rgba(11, 9, 26, .78));
  backdrop-filter: blur(7px); -webkit-backdrop-filter: blur(7px);
}
.panel, .tile, .agent-card { border-color: rgba(76, 60, 140, .55); }
.tile::before { height: 2px; box-shadow: 0 0 12px var(--tile-c, var(--acc)); }
.sidebar {
  background: linear-gradient(180deg, rgba(12, 9, 32, .82), rgba(8, 6, 23, .9));
  backdrop-filter: blur(9px); -webkit-backdrop-filter: blur(9px);
}
.gw-menu, .token-box {
  background: linear-gradient(170deg, rgba(19, 16, 49, .92), rgba(12, 9, 32, .95));
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}

/* Four structural appearance modes: minimalist, brutalist, glassmorph, cyberpunk. */
.theme-pick { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; padding: 0 8px; }
.theme-sw {
  position: relative; width: 100%; min-height: 42px; border-radius: var(--control-radius, 7px); cursor: pointer;
  border: 1px solid var(--line); background: var(--sw-bg, #0A0A14); transition: border-color .15s, box-shadow .15s, transform .15s;
  padding: 0;
}
.theme-sw::after {
  content: ""; position: absolute; width: 9px; height: 9px; top: 8px; left: 8px; border-radius: 50%;
  background: var(--sw, var(--acc)); box-shadow: 0 0 7px var(--sw, var(--acc));
}
.theme-sw:hover { border-color: var(--sw); transform: translateY(-1px); }
.theme-sw.on { border-color: var(--sw); box-shadow: 0 0 10px color-mix(in srgb, var(--sw) 55%, transparent); }
/* label reads against the swatch's own preview bg, not the active theme */
.theme-sw-label { display: block; padding: 19px 5px 4px; color: var(--sw, var(--text)); font: 700 7px/1.1 var(--mono); text-transform: uppercase; letter-spacing: .04em; }
.theme-name {
  font-family: var(--mono); font-size: 9px; letter-spacing: .14em; color: var(--acc);
  text-transform: uppercase; padding: 6px 8px 0; opacity: .85;
}
.brand-name { line-height: 1.25; }

/* ---------------- add-agent modal ---------------- */
.aa-box { width: min(560px, 92vw); }
/* ＋ Add Agent — curated catalog grid (install path) above the custom form */
.aa-catalog { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 10px 0 4px; }
.aa-cat-card {
  display: flex; align-items: center; gap: 10px; padding: 9px 11px; min-width: 0;
  background: var(--card); border: var(--surface-border-width) var(--surface-border-style) var(--line);
  border-radius: var(--control-radius);
}
.aa-cat-icon { font-size: 17px; flex: none; }
.aa-cat-body { min-width: 0; margin-right: auto; display: flex; flex-direction: column; }
.aa-cat-body b { font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.aa-cat-body small { font-size: 10px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.aa-cat-card .btn { flex: none; font-size: 10px; padding: 4px 8px; }
.aa-cat-state { font-family: var(--font-data); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); flex: none; }
.aa-cat-state.ok { color: var(--lime); }
.aa-cat-state a { color: var(--cyan); text-decoration: none; }
.aa-cat-log {
  margin: 8px 0 0; padding: 8px 10px; max-height: 130px; overflow: auto;
  font-family: var(--font-data); font-size: 10px; line-height: 1.5; white-space: pre-wrap; word-break: break-word;
  background: var(--graph-panel); color: var(--text);
  border: var(--surface-border-width) var(--surface-border-style) var(--line); border-radius: var(--control-radius);
}
.aa-custom-head { margin-top: 14px; border-top: 1px solid var(--line); padding-top: 10px; }
@media (max-width: 560px) { .aa-catalog { grid-template-columns: 1fr; } }

/* Update banner — silent unless GitHub has a strictly newer release */
.update-banner {
  margin: 0 0 12px; padding: 10px 14px;
  background: var(--card); border: var(--surface-border-width) var(--surface-border-style) var(--acc);
  border-radius: var(--surface-radius); box-shadow: var(--surface-shadow);
}
.update-banner.phase-done { border-color: var(--lime); }
.update-banner.phase-failed { border-color: var(--red); }
.update-banner-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 12px; }
.update-banner-badge { color: var(--acc); font-weight: 700; }
.update-banner-link {
  background: none; border: none; padding: 0; cursor: pointer;
  color: var(--cyan); font: inherit; font-size: 11px; text-decoration: underline;
}
.update-banner-spin { color: var(--muted); font-family: var(--font-data); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; }
.update-banner-notes {
  margin: 8px 0 0; padding: 8px 10px; max-height: 180px; overflow: auto;
  font-family: var(--font-data); font-size: 10px; line-height: 1.5; white-space: pre-wrap; word-break: break-word;
  background: var(--graph-panel); color: var(--text);
  border: var(--surface-border-width) var(--surface-border-style) var(--line); border-radius: var(--control-radius);
}
.aa-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.aa-field { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.aa-field.wide { grid-column: 1 / -1; }
.aa-field label { font-family: var(--mono); font-size: 9px; letter-spacing: .16em; color: var(--muted); text-transform: uppercase; }
.aa-field input {
  padding: 8px 10px; border-radius: 7px; border: 1px solid var(--line);
  background: var(--bg); color: var(--text); font: 12px var(--mono); min-width: 0;
}
.aa-field input:focus { outline: none; border-color: var(--acc); }
.aa-field input[type="color"] { padding: 2px 4px; height: 34px; cursor: pointer; }
.aa-actions { display: flex; flex-direction: row; align-items: center; gap: 8px; justify-content: flex-end; margin-top: 4px; }
.aa-hint { font-size: 10.5px; color: var(--muted); font-family: var(--mono); min-height: 14px; }
.aa-hint.err { color: var(--red); }

/* ---------------- workspace (the front door) ----------------
   Hero = the project you continue; everything on it is live data:
   progress rail (checkbox ratio), status, agent constellation, last decision. */
.ws-hero {
  position: relative; overflow: hidden;
  border: 1px solid color-mix(in srgb, var(--ac, var(--acc)) 38%, var(--line));
  border-radius: 14px; padding: 20px 22px 18px; margin-bottom: 22px;
  background: linear-gradient(165deg, rgba(19, 16, 49, .72), rgba(11, 9, 26, .82));
  backdrop-filter: blur(7px); -webkit-backdrop-filter: blur(7px);
  box-shadow: 0 0 34px color-mix(in srgb, var(--ac, var(--acc)) 14%, transparent);
}
.ws-hero::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--ac, var(--acc)), transparent 70%);
  box-shadow: 0 0 14px var(--ac, var(--acc));
}
.ws-eyebrow { font-family: var(--mono); font-size: 9.5px; letter-spacing: .24em; color: var(--ac, var(--acc)); opacity: .9; margin-bottom: 10px; }
.ws-hero-row { display: flex; gap: 20px; align-items: flex-start; }
.ws-hero-main { flex: 1; min-width: 0; }
.ws-hero-name {
  font-family: var(--hero); font-weight: 900; font-size: 26px; letter-spacing: .06em;
  background: linear-gradient(90deg, var(--text) 40%, var(--ac, var(--acc)));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 16px color-mix(in srgb, var(--ac, var(--acc)) 30%, transparent));
}
.ws-goal { color: var(--muted); font-size: 12.5px; margin: 5px 0 12px; max-width: 640px; }
.ws-hero-act { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; flex-shrink: 0; }
.ws-continue { font-size: 13px; padding: 11px 22px; letter-spacing: .16em; }
.ws-last { font-family: var(--mono); font-size: 10.5px; color: var(--muted); margin-top: 10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* progress rail — hero variant carries the one orchestrated motion moment (scan sweep) */
.ws-prog { position: relative; height: 6px; border-radius: 999px; background: rgba(255, 255, 255, .07); overflow: hidden; margin: 8px 0 7px; }
.ws-prog i {
  display: block; height: 100%; border-radius: 999px;
  background: linear-gradient(90deg, var(--ac, var(--acc)), color-mix(in srgb, var(--ac, var(--acc)) 55%, var(--magenta)));
  box-shadow: 0 0 10px color-mix(in srgb, var(--ac, var(--acc)) 60%, transparent);
  transition: width .5s ease;
}
.ws-prog-hero { height: 8px; }
@media (prefers-reduced-motion: no-preference) {
  .ws-prog-hero::after {
    content: ""; position: absolute; inset: 0; border-radius: 999px;
    background: linear-gradient(90deg, transparent 20%, rgba(238, 235, 255, .28), transparent 80%);
    background-size: 200% 100%; animation: wsScan 3.4s ease-in-out infinite;
  }
  @keyframes wsScan { from { background-position: 180% 0; } to { background-position: -80% 0; } }
}

.ws-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
.ws-card {
  text-align: left; cursor: pointer; min-width: 0;
  border: 1px solid var(--line); border-radius: 12px; padding: 13px 14px;
  background: linear-gradient(165deg, rgba(19, 16, 49, .68), rgba(11, 9, 26, .78));
  backdrop-filter: blur(7px); -webkit-backdrop-filter: blur(7px);
  color: var(--text); font: inherit;
  transition: transform .15s, border-color .15s, box-shadow .15s;
}
.ws-card:hover { transform: translateY(-2px); border-color: var(--acc); box-shadow: 0 0 20px color-mix(in srgb, var(--acc) 20%, transparent); }
.ws-card:focus-visible { outline: 2px solid var(--acc); outline-offset: 2px; }
.ws-card-top { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
.ws-card-name { font-family: var(--disp); font-weight: 700; font-size: 13.5px; letter-spacing: .04em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ws-card-goal { color: var(--muted); font-size: 11px; margin-top: 3px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.ws-card-meta { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 9.5px; color: var(--muted); }
.ws-card-meta span:last-child { margin-left: auto; }
@media (prefers-reduced-motion: no-preference) {
  .ws-card, .ws-hero { animation: wsIn .35s cubic-bezier(.2, .65, .3, 1) backwards; }
  @keyframes wsIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
}

.ws-status {
  font-family: var(--mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase;
  padding: 1px 8px; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); flex-shrink: 0;
}
.ws-status.st-active { border-color: var(--lime); color: var(--lime); }
.ws-status.st-done, .ws-status.st-shipped { border-color: var(--cyan); color: var(--cyan); }
.ws-status.st-blocked { border-color: var(--red); color: var(--red); }
.ws-agents { display: inline-flex; gap: 3px; }
.ws-agents i { width: 8px; height: 8px; border-radius: 50%; box-shadow: 0 0 6px currentColor; }

/* project panel (reuses .detail chrome) */
.ws-detail .detail-meta { display: flex; align-items: center; gap: 8px; }
.ws-next { font-size: 12.5px; line-height: 1.55; border-left: 2px solid var(--ac, var(--acc)); padding: 6px 10px; background: rgba(255, 255, 255, .02); border-radius: 0 7px 7px 0; }
.ws-dec {
  font-size: 11.5px; line-height: 1.5; padding: 7px 9px;
  border-bottom: 1px solid rgba(36, 30, 78, .6);
}
.ws-dec:last-child { border-bottom: none; }
.ws-hint { font-family: var(--mono); font-size: 10px; color: var(--muted); min-height: 14px; margin-top: 4px; }

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
.today-error { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; padding: 10px 12px; border: 1px solid var(--red); border-radius: 8px; color: var(--red); }
.today-context { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 0 0 18px; }
.today-panel { min-width: 0; padding: 14px; border: 1px solid var(--line); border-radius: 11px; background: color-mix(in srgb, var(--panel) 88%, transparent); }
.today-panel h3, .approval-head h2 { margin: 0 0 10px; font: 700 12px var(--disp); letter-spacing: .04em; }
.today-next { grid-column: 1 / -1; display: grid; grid-template-columns: minmax(130px, .45fr) minmax(0, 1.6fr) auto; align-items: center; gap: 16px; border-color: color-mix(in srgb, var(--acc) 42%, var(--line)); }
.today-next strong { font-size: 14px; line-height: 1.45; }
.today-next > span { color: var(--muted); font: 10px var(--mono); }
.today-label { color: var(--acc); font: 9px var(--mono); letter-spacing: .16em; }
.today-list { list-style: none; display: grid; gap: 7px; margin: 0; padding: 0; }
.today-list li { display: flex; align-items: flex-start; gap: 8px; min-width: 0; font-size: 11.5px; line-height: 1.4; }
.today-list a { color: var(--text); text-decoration-color: var(--line); text-underline-offset: 3px; overflow-wrap: anywhere; }
.approval-queue { margin: 0 0 22px; padding: 14px; border: 1px solid var(--line); border-radius: 11px; background: color-mix(in srgb, var(--panel) 88%, transparent); }
.approval-head, .approval-item { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.approval-head h2 { margin: 3px 0 0; }
.approval-item { padding: 12px 0; border-top: 1px solid var(--line); }
.approval-copy { display: grid; gap: 4px; min-width: 0; }
.approval-copy strong { font-size: 12px; }
.approval-copy span { color: var(--muted); font: 10px var(--mono); overflow-wrap: anywhere; }
.approval-copy b { color: var(--text); font-weight: 600; }
.approval-actions { display: flex; gap: 8px; flex-shrink: 0; }
.approval-actions .btn, .today-error .btn, .section-row .btn { min-height: 44px; }

/* Stage C: project continuity is the one visual hero on Today. Every satellite
   is sourced from the current /api/today project projection. */
.continuity-hero {
  position: relative; display: grid; grid-template-columns: minmax(280px, .82fr) minmax(420px, 1.18fr);
  gap: clamp(24px, 4vw, 58px); overflow: hidden; margin: 0 0 18px; padding: clamp(22px, 3vw, 38px);
  border-width: var(--surface-border-width); border-style: var(--surface-border-style); border-color: var(--surface-border);
  border-radius: var(--surface-radius); background: var(--surface-fill); box-shadow: var(--surface-shadow);
  backdrop-filter: blur(var(--surface-blur)); -webkit-backdrop-filter: blur(var(--surface-blur));
}
.lyr:disabled { cursor: not-allowed; opacity: .55; box-shadow: none; }
@media (max-width: 1180px) {
  .graph-bar { grid-template-columns: minmax(140px, .7fr) minmax(180px, 1fr) auto; }
  .graph-layers, .graph-modes { grid-column: span 1; }
  .graph-open { justify-self: end; }
}
@media (max-width: 860px) {
  .graph-bar { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); align-items: stretch; }
  .graph-heading, .graph-search { min-width: 0; }
  .graph-layers, .graph-modes { grid-column: 1 / -1; justify-content: flex-start; flex-wrap: wrap; border-radius: 10px; }
  .graph-open { grid-column: 1 / -1; justify-self: start; }
  .graph-workspace { grid-template-columns: 1fr; overflow: auto; }
  .graph-wrap { min-height: 55vh; }
  .graph-inspector { overflow: visible; }
}
.continuity-hero::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: var(--ac, var(--acc)); }
.continuity-copy { align-self: center; min-width: 0; }
.continuity-copy .ws-hero-name { margin: 0; overflow-wrap: anywhere; }
.continuity-next { display: grid; gap: 5px; margin: 20px 0; padding: 14px 0; border-block: 1px solid var(--line); }
.continuity-next span, .continuity-core span, .continuity-node > span, .continuity-node :is(a,button) span {
  color: var(--muted); font: 9px var(--font-data, var(--mono)); letter-spacing: .13em; text-transform: uppercase;
}
.continuity-next strong { max-width: 52ch; font: 650 15px/1.45 var(--font-ui, var(--sans)); }
.continuity-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.continuity-actions :is(.btn,.continuity-link) { min-height: 44px; display: inline-flex; align-items: center; justify-content: center; }
.continuity-link { text-decoration: none; }
.continuity-map { position: relative; align-self: center; display: grid; grid-template-columns: minmax(128px, .55fr) minmax(210px, 1fr); align-items: center; gap: 28px; min-height: 300px; }
.continuity-map::before { content: ""; position: absolute; left: calc(36% - 28px); top: 12%; bottom: 12%; width: 1px; background: color-mix(in srgb, var(--ac, var(--acc)) 52%, var(--line)); }
.continuity-core {
  position: relative; z-index: 1; display: grid; place-content: center; gap: 7px; min-height: 138px; padding: 20px;
  border: 1px solid var(--ac, var(--acc)); border-radius: calc(var(--surface-radius) * 1.35); background: color-mix(in srgb, var(--surface-fill) 86%, var(--ac, var(--acc)) 14%);
}
.continuity-core::after { content: ""; position: absolute; right: -29px; top: 50%; width: 29px; height: 1px; background: var(--ac, var(--acc)); }
.continuity-core strong { overflow-wrap: anywhere; font: 700 clamp(16px, 2vw, 23px)/1.15 var(--font-heading, var(--disp)); }
.continuity-nodes { display: grid; gap: 10px; margin: 0; padding: 0; list-style: none; }
.continuity-node { position: relative; min-width: 0; padding: 9px 0 9px 18px; border-left: 1px solid var(--line); }
.continuity-node::before { content: ""; position: absolute; left: -4px; top: 18px; width: 7px; height: 7px; border: 1px solid var(--ac, var(--acc)); border-radius: 50%; background: var(--bg); }
.continuity-node > strong, .continuity-node :is(a,button) strong { display: block; margin-top: 3px; overflow: hidden; color: var(--text); font: 600 11.5px/1.35 var(--font-ui, var(--sans)); text-overflow: ellipsis; white-space: nowrap; }
.continuity-node :is(a,button) { display: block; width: 100%; min-height: 44px; padding: 0; border: 0; background: transparent; color: inherit; text-align: left; text-decoration: none; cursor: pointer; }
.continuity-node :is(a,button):hover strong { color: var(--ac, var(--acc)); }
.continuity-strip { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0; border-top: 1px solid var(--line); }
.continuity-strip span { display: grid; gap: 3px; padding: 12px 14px 0; color: var(--muted); font: 10px/1.35 var(--font-data, var(--mono)); }
.continuity-strip span + span { border-left: 1px solid var(--line); }
.continuity-strip b { color: var(--text); font-weight: 650; }
.continuity-loading { height: 420px; margin-bottom: 18px; }

/* Project Workspace: one stable shell, six honest destinations. */
.project-workspace-wrap { margin-top: 22px; scroll-margin-top: 18px; }
.project-workspace { overflow: hidden; }
.project-workspace .detail-head { padding-block: 18px; }
.project-workspace .detail-meta { flex-wrap: wrap; row-gap: 6px; }
.project-workspace .detail-actions { align-items: stretch; }
.project-workspace .detail-actions :is(.btn,.project-link) { min-height: 44px; display: inline-flex; align-items: center; justify-content: center; }
.project-link { text-decoration: none; }
.project-tabs { display: flex; align-items: stretch; overflow-x: auto; border-block: 1px solid var(--line); background: color-mix(in srgb, var(--panel) 76%, transparent); scrollbar-width: thin; }
.project-tabs button { flex: 1 0 auto; min-width: 110px; min-height: 48px; padding: 0 16px; border: 0; border-right: 1px solid var(--line); background: transparent; color: var(--muted); font: 650 10px var(--font-data, var(--mono)); letter-spacing: .1em; text-transform: uppercase; cursor: pointer; }
.project-tabs button.active { color: var(--text); background: color-mix(in srgb, var(--ac, var(--acc)) 12%, transparent); box-shadow: inset 0 -2px var(--ac, var(--acc)); }
.project-panels { min-height: 330px; padding: clamp(18px, 3vw, 30px); }
.project-panels > section[hidden] { display: none; }
.project-panels > section { animation: projectPanelIn .18s ease-out; }
@media (prefers-reduced-motion: no-preference) { @keyframes projectPanelIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: none; } } }
.project-overview-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 24px; }
.project-overview-grid article { min-width: 0; padding-bottom: 18px; border-bottom: 1px solid var(--line); }
.project-goal { max-width: 65ch; margin: 10px 0 16px; font: 600 clamp(16px, 2vw, 22px)/1.4 var(--font-heading, var(--disp)); }
.project-assignees { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; padding: 16px 0; color: var(--muted); font-size: 11px; }
.project-composer { margin-top: 8px; padding: 18px; border: 1px solid var(--line); background: color-mix(in srgb, var(--panel) 72%, transparent); }
.project-composer h3, .project-section-head h3 { margin: 0; color: var(--text); font: 700 17px var(--font-heading, var(--disp)); }
.project-composer p { margin: 5px 0 14px; color: var(--muted); font-size: 11px; }
.ws-composer, .decision-form { align-items: end; }
.ws-composer label, .decision-form label { color: var(--muted); font: 9px var(--font-data, var(--mono)); letter-spacing: .1em; text-transform: uppercase; }
.ws-composer select { min-width: 190px; max-width: none; min-height: 44px; }
.ws-composer .btn, .decision-form .btn { min-height: 44px; }
.project-section-head { display: flex; align-items: center; justify-content: space-between; gap: 18px; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid var(--line); }
.project-task-list { display: grid; gap: 0; margin: 0; padding: 0; list-style: none; }
.project-task-list li { display: flex; align-items: center; gap: 12px; min-height: 48px; border-bottom: 1px solid var(--line); font-size: 12px; }
.project-memory { max-height: 330px; overflow: auto; margin: 16px 0 0; padding: 18px; border-left: 2px solid var(--ac, var(--acc)); background: color-mix(in srgb, var(--panel) 78%, transparent); color: var(--text); font: 11.5px/1.65 var(--font-data, var(--mono)); white-space: pre-wrap; }
.project-files { display: grid; }
.project-files a { display: flex; align-items: center; justify-content: space-between; gap: 18px; min-height: 48px; padding: 8px 0; border-bottom: 1px solid var(--line); color: var(--text); text-decoration: none; }
.project-files a:hover span { color: var(--ac, var(--acc)); }
.project-files time { flex: 0 0 auto; color: var(--muted); font: 9.5px var(--font-data, var(--mono)); }
.decision-form { display: grid; grid-template-columns: minmax(120px, .3fr) minmax(220px, 1fr) auto; gap: 8px; }
.decision-form input { min-height: 44px; }
.decision-list { margin-top: 16px; }
.project-status { min-height: 32px; padding: 0 clamp(18px, 3vw, 30px) 16px; color: var(--muted); font: 10px var(--font-data, var(--mono)); }
.project-loading { height: 260px; }
.aa-actions .btn { min-height: 44px; }

/* ---------------- cosmos agent map ---------------- */
/* Full-bleed stage: the map view zeroes the main padding (theme override in themes.css). */
.main-flush { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
.cosmos-view { display: flex; flex-direction: column; flex: 1; min-height: 0; }
.cosmos-view.view.active { animation: none; }

.cosmos-topbar {
  height: 52px; flex: 0 0 auto; display: flex; align-items: center; gap: 10px;
  padding: 0 20px; position: relative;
  background: var(--cosmos-panel); border-bottom: 1px solid var(--cosmos-line);
}
.cosmos-topbar-left { display: flex; align-items: center; gap: 10px; z-index: 1; }
.cosmos-chip {
  display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: var(--control-radius, 6px);
  font: 700 8.5px var(--font-heading, var(--disp)); letter-spacing: .14em; color: var(--cosmos-accent);
  background: color-mix(in srgb, var(--cosmos-accent) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--cosmos-accent) 22%, transparent);
}
.cosmos-title-wrap { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; }
.cosmos-title { display: flex; align-items: center; gap: 14px; font: 800 14px var(--font-heading, var(--disp)); letter-spacing: .38em; color: var(--cosmos-ink); text-indent: .38em; }
.cosmos-title .cx-plus { font-size: 11px; color: color-mix(in srgb, var(--cosmos-accent) 30%, transparent); text-indent: 0; }
.cosmos-subtitle { margin-top: 2px; font: 7.5px var(--font-data, var(--mono)); letter-spacing: .14em; color: var(--cosmos-dim); }
.cosmos-topbar-right { margin-left: auto; display: flex; align-items: center; gap: 20px; z-index: 1; }
.cosmos-stat { display: flex; flex-direction: column; align-items: flex-end; gap: 1px; }
.cosmos-stat-label { display: inline-flex; align-items: center; gap: 5px; font: 700 7.5px var(--font-heading, var(--disp)); letter-spacing: .12em; color: var(--cosmos-dim); }
.cosmos-stat-label i { width: 6px; height: 6px; border-radius: 50%; background: var(--cosmos-dim); }
.cosmos-stat-label.is-ok { color: var(--cosmos-ok); }
.cosmos-stat-label.is-ok i { background: var(--cosmos-ok); box-shadow: 0 0 8px var(--cosmos-ok); }
.cosmos-stat-label.is-warn { color: var(--cosmos-status-error); }
.cosmos-stat-label.is-warn i { background: var(--cosmos-status-error); box-shadow: 0 0 8px var(--cosmos-status-error); }
.cosmos-stat b { font: 700 9.5px var(--font-heading, var(--disp)); letter-spacing: .08em; color: var(--cosmos-ink); }
.cosmos-stat b.is-amber { font-size: 10.5px; color: var(--cosmos-amber); }
.cosmos-clock { min-width: 76px; text-align: right; font: 700 15px var(--font-heading, var(--disp)); letter-spacing: .12em; color: var(--cosmos-accent); }

.cosmos-alert { flex: 0 0 auto; margin: 10px 16px 0; padding: 9px 12px; border: 1px solid var(--cosmos-status-error); border-radius: var(--control-radius, 7px); color: var(--cosmos-status-error); font: 11px var(--font-data, var(--mono)); }
.cosmos-stage-row { flex: 1; display: flex; min-height: 0; }
.cosmos-stage {
  flex: 1; position: relative; overflow: hidden; min-width: 0;
  background: radial-gradient(ellipse at 50% 46%, var(--cosmos-canvas-mid) 0%, var(--cosmos-canvas) 68%);
}
.cosmos-svg { width: 100%; height: 100%; display: block; }
.cosmos-note {
  position: absolute; top: 14px; left: 50%; transform: translateX(-50%); z-index: 11;
  display: flex; align-items: center; gap: 10px; max-width: min(520px, calc(100% - 32px)); padding: 9px 14px;
  border: 1px solid var(--cosmos-line); border-left: 3px solid var(--cosmos-accent); border-radius: var(--control-radius, 7px);
  background: var(--cosmos-panel); color: var(--cosmos-body); font: 10.5px/1.5 var(--font-data, var(--mono));
}
.cosmos-note strong { color: var(--cosmos-ink); font-family: var(--font-heading, var(--disp)); }

.cosmos-zoom { position: absolute; top: 16px; right: 16px; z-index: 10; display: flex; flex-direction: column; gap: 6px; }
.cosmos-zoom button {
  width: 34px; height: 34px; display: grid; place-items: center; cursor: pointer;
  border-radius: var(--control-radius, 6px); color: var(--cosmos-dim);
  background: color-mix(in srgb, var(--cosmos-canvas) 82%, transparent);
  border: 1px solid color-mix(in srgb, var(--cosmos-accent) 14%, transparent);
  transition: color .15s, border-color .15s;
}
.cosmos-zoom button:hover:not(:disabled) { color: var(--cosmos-accent); border-color: color-mix(in srgb, var(--cosmos-accent) 45%, transparent); }
.cosmos-zoom button:disabled { opacity: .35; cursor: not-allowed; }

.cosmos-legend {
  position: absolute; bottom: 14px; left: 14px; z-index: 10;
  display: flex; align-items: center; gap: 13px; flex-wrap: wrap; max-width: calc(100% - 28px);
  padding: 8px 12px; border-radius: var(--control-radius, 6px);
  background: color-mix(in srgb, var(--cosmos-canvas) 84%, transparent); border: 1px solid var(--cosmos-line);
}
.cosmos-legend .lg-title { font: 700 7px var(--font-heading, var(--disp)); letter-spacing: .18em; color: var(--cosmos-dim); }
.cosmos-legend .lg { font: 7.5px var(--font-data, var(--mono)); letter-spacing: .04em; white-space: nowrap; }
.lg-status.status-running { color: var(--cosmos-status-running); }
.lg-status.status-idle { color: var(--cosmos-status-idle); }
.lg-status.status-observe { color: var(--cosmos-status-observe); }
.lg-status.status-error { color: var(--cosmos-status-error); }
.lg-status.status-disabled { color: var(--cosmos-status-disabled); }
.lg-tier.tier-strong { color: var(--cosmos-conn-strong); }
.lg-tier.tier-data { color: var(--cosmos-conn-data); }
.lg-tier.tier-weak { color: color-mix(in srgb, var(--cosmos-conn-weak) 60%, var(--cosmos-body)); }
.lg-tier.tier-lane { color: var(--cosmos-dim); }

/* SVG stage marks */
.cosmos-star { fill: var(--cosmos-star); }
.cosmos-edge { fill: none; pointer-events: none; }
.cosmos-edge.tier-strong, .cosmos-particle.tier-strong { stroke: var(--cosmos-conn-strong); }
.cosmos-edge.tier-data, .cosmos-particle.tier-data { stroke: var(--cosmos-conn-data); }
.cosmos-edge.tier-weak, .cosmos-particle.tier-weak { stroke: var(--cosmos-conn-weak); }
.cosmos-particle { pointer-events: none; }
.cosmos-particle.tier-strong { fill: var(--cosmos-conn-strong); }
.cosmos-particle.tier-data { fill: var(--cosmos-conn-data); }
.cosmos-edge-hit { fill: none; stroke: transparent; stroke-width: 16; cursor: pointer; pointer-events: stroke; }
.cosmos-lane { fill: none; stroke: var(--cosmos-conn-weak); stroke-width: 1; stroke-dasharray: 2 6; opacity: .5; pointer-events: none; }
.cosmos-node { cursor: pointer; }
.cosmos-node:focus-visible { outline: none; }
.cosmos-node:focus-visible .cosmos-node-outer { stroke-dasharray: 4 4; opacity: 1; }
.cosmos-node-body { fill: var(--cosmos-node-fill); }
.cosmos-node-outer { fill: none; stroke-width: .8; }
.cosmos-halo { pointer-events: none; }
.cosmos-ring { fill: none; stroke-width: .5; pointer-events: none; }
.cosmos-pulse { fill: none; stroke-width: 1.5; opacity: .7; pointer-events: none; }
.cosmos-spin { transform-box: fill-box; transform-origin: center; }
.cosmos-node-name { fill: var(--cosmos-name); font: 600 9px var(--font-heading, var(--disp)); letter-spacing: 1px; pointer-events: none; }
.cosmos-node-state { font: 7px var(--font-data, var(--mono)); pointer-events: none; }
.cosmos-node-state.status-running { fill: var(--cosmos-status-running); }
.cosmos-node-state.status-idle { fill: var(--cosmos-status-idle); }
.cosmos-node-state.status-observe { fill: var(--cosmos-status-observe); }
.cosmos-node-state.status-error { fill: var(--cosmos-status-error); }
.cosmos-node-state.status-disabled { fill: var(--cosmos-status-disabled); }
.cosmos-core-name { fill: var(--cosmos-ink); font: 700 12px var(--font-heading, var(--disp)); letter-spacing: 2px; pointer-events: none; }
.cosmos-core-sub { fill: var(--cosmos-core); font: 7.5px var(--font-heading, var(--disp)); letter-spacing: 3px; opacity: .7; pointer-events: none; }
.cosmos-core-dot { fill: var(--cosmos-status-idle); stroke: var(--cosmos-canvas); stroke-width: 1.5; }
.cosmos-core-dot.is-live { fill: var(--cosmos-status-running); filter: drop-shadow(0 0 5px var(--cosmos-status-running)); }

/* right detail panel */
.cosmos-detail {
  width: 294px; flex: 0 0 auto; overflow-y: auto; scrollbar-width: thin;
  background: var(--cosmos-panel); border-left: 1px solid var(--cosmos-line);
}
.cd-empty { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: color-mix(in srgb, var(--cosmos-accent) 26%, transparent); }
.cd-empty span { font: 700 9px var(--font-heading, var(--disp)); letter-spacing: .18em; color: var(--cosmos-dim); }
.cd-body { min-height: 100%; }
.cd-head { padding: 16px 16px 12px; border-bottom: 1px solid var(--cosmos-line); }
.cd-head-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
.cd-icon-tile {
  position: relative; width: 44px; height: 44px; flex: 0 0 auto; display: grid; place-items: center;
  border-radius: 12px; background: color-mix(in srgb, var(--cd-c, var(--cosmos-accent)) 9%, transparent);
  border: 1px solid color-mix(in srgb, var(--cd-c, var(--cosmos-accent)) 28%, transparent);
  box-shadow: 0 0 22px color-mix(in srgb, var(--cd-c, var(--cosmos-accent)) 10%, transparent);
}
.cd-status-dot { position: absolute; top: -4px; right: -4px; width: 13px; height: 13px; border-radius: 50%; border: 2px solid var(--cosmos-canvas); }
.cd-title { min-width: 0; }
.cd-title h3 { margin: 0; font: 700 12.5px/1.2 var(--font-heading, var(--disp)); letter-spacing: .06em; color: var(--cosmos-ink); overflow-wrap: anywhere; }
.cd-title span { display: block; margin-top: 3px; font: 7.5px var(--font-data, var(--mono)); letter-spacing: .1em; }
.cd-more { margin-left: auto; padding: 2px; border: 0; background: transparent; color: var(--cosmos-dim); cursor: pointer; }
.cd-more:hover { color: var(--cosmos-accent); }
.cd-badges { display: flex; flex-wrap: wrap; gap: 6px; }
.cd-badge {
  padding: 2px 8px; border-radius: 4px; font: 700 7.5px var(--font-heading, var(--disp)); letter-spacing: .14em;
  color: var(--cosmos-dim); border: 1px solid var(--cosmos-line); background: transparent;
}
.cd-badge.status-running { color: var(--cosmos-status-running); border-color: color-mix(in srgb, var(--cosmos-status-running) 35%, transparent); background: color-mix(in srgb, var(--cosmos-status-running) 9%, transparent); }
.cd-badge.status-idle, .cd-badge.status-observe { color: var(--cosmos-status-idle); border-color: color-mix(in srgb, var(--cosmos-status-idle) 35%, transparent); background: color-mix(in srgb, var(--cosmos-status-idle) 9%, transparent); }
.cd-badge.status-error { color: var(--cosmos-status-error); border-color: color-mix(in srgb, var(--cosmos-status-error) 35%, transparent); background: color-mix(in srgb, var(--cosmos-status-error) 9%, transparent); }
.cd-badge.status-disabled { color: var(--cosmos-status-disabled); }
.cd-badge-core { color: var(--cosmos-accent); border-color: color-mix(in srgb, var(--cosmos-accent) 25%, transparent); background: color-mix(in srgb, var(--cosmos-accent) 8%, transparent); }
.cd-desc { padding: 12px 16px; border-bottom: 1px solid color-mix(in srgb, var(--cosmos-line) 70%, transparent); font: 400 12px/1.65 var(--font-ui, var(--sans)); color: var(--cosmos-body); }
.cd-route { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.cd-route b { color: var(--cosmos-ink); font-family: var(--font-heading, var(--disp)); font-size: 11px; }
.cd-chips { display: flex; flex-wrap: wrap; gap: 6px; padding: 12px 16px; border-bottom: 1px solid color-mix(in srgb, var(--cosmos-line) 70%, transparent); }
.cd-chip {
  padding: 2px 6px; border-radius: 3px; font: 7px var(--font-data, var(--mono)); letter-spacing: .08em;
  color: color-mix(in srgb, var(--cosmos-conn-data) 75%, var(--cosmos-body));
  background: color-mix(in srgb, var(--cosmos-conn-data) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--cosmos-conn-data) 22%, transparent);
}
.cd-section { padding: 12px 16px; border-bottom: 1px solid color-mix(in srgb, var(--cosmos-line) 70%, transparent); }
.cd-section-head { display: flex; align-items: center; gap: 7px; margin-bottom: 10px; font: 700 8.5px var(--font-heading, var(--disp)); letter-spacing: .14em; color: var(--cosmos-dim); }
.cd-conn-list { display: flex; flex-direction: column; gap: 7px; }
.cd-conn {
  display: flex; align-items: center; gap: 8px; width: 100%; min-height: 30px; padding: 3px 4px;
  border: 0; border-radius: 5px; background: transparent; color: inherit; text-align: left; cursor: pointer; font: inherit;
}
.cd-conn:hover, .cd-conn:focus-visible { background: color-mix(in srgb, var(--cosmos-accent) 7%, transparent); }
.cd-conn-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font: 600 11px var(--font-ui, var(--sans)); color: var(--cosmos-body); }
.cd-conn small { flex: 0 0 auto; font: 7px var(--font-data, var(--mono)); letter-spacing: .04em; color: var(--cosmos-dim); text-transform: uppercase; }
.cd-conn-dot { width: 6px; height: 6px; border-radius: 50%; flex: 0 0 auto; background: var(--cosmos-status-disabled); }
.cd-conn-dot.status-running { background: var(--cosmos-status-running); }
.cd-conn-dot.status-idle, .cd-conn-dot.status-observe { background: var(--cosmos-status-idle); }
.cd-conn-dot.status-error { background: var(--cosmos-status-error); }
.cd-conn-bar { width: 52px; height: 3px; flex: 0 0 auto; border-radius: 999px; overflow: hidden; background: color-mix(in srgb, var(--cosmos-accent) 8%, transparent); }
.cd-conn-bar i { display: block; height: 100%; border-radius: 999px; }
.cd-conn-bar i.tier-strong { background: linear-gradient(to right, color-mix(in srgb, var(--cosmos-conn-strong) 40%, transparent), var(--cosmos-conn-strong)); }
.cd-conn-bar i.tier-data { background: linear-gradient(to right, color-mix(in srgb, var(--cosmos-conn-data) 40%, transparent), var(--cosmos-conn-data)); }
.cd-conn-bar i.tier-weak { background: color-mix(in srgb, var(--cosmos-conn-weak) 80%, var(--cosmos-body)); }
.cd-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 9px; }
.cd-bar-row:last-child { margin-bottom: 0; }
.cd-bar-label { width: 82px; flex: 0 0 auto; font: 8.5px var(--font-data, var(--mono)); letter-spacing: .05em; color: var(--cosmos-dim); }
.cd-bar { flex: 1; height: 3px; border-radius: 999px; overflow: hidden; background: color-mix(in srgb, var(--cosmos-accent) 8%, transparent); }
.cd-bar i { display: block; height: 100%; border-radius: 999px; }
.cd-bar-value { min-width: 44px; flex: 0 0 auto; text-align: right; font: 9px var(--font-data, var(--mono)); }
.cd-meta { display: flex; flex-direction: column; gap: 8px; }
.cd-meta-row { display: flex; justify-content: space-between; gap: 12px; }
.cd-meta-row span { font: 7.5px var(--font-data, var(--mono)); letter-spacing: .05em; color: var(--cosmos-dim); white-space: nowrap; }
.cd-meta-row b { font: 7.5px var(--font-data, var(--mono)); letter-spacing: .03em; color: var(--cosmos-body); font-weight: 400; text-align: right; overflow-wrap: anywhere; }
.cd-actions { padding: 14px 16px 18px; }
.cd-actions .btn { width: 100%; }

/* footer strip: keyboard help + evidence table + policy line */
.cosmos-foot {
  flex: 0 0 auto; display: flex; align-items: center; gap: 16px; padding: 5px 16px;
  background: var(--cosmos-panel); border-top: 1px solid var(--cosmos-line);
}
.cosmos-key-help { font: 8.5px var(--font-data, var(--mono)); color: var(--cosmos-dim); white-space: nowrap; }
.cosmos-policy { margin-left: auto; font: 8px var(--font-data, var(--mono)); letter-spacing: .18em; color: var(--cosmos-dim); white-space: nowrap; }
.cosmos-evidence { flex: 1; min-width: 0; margin: 0; border: 0; background: transparent; }
.cosmos-evidence summary { padding: 6px 8px; color: var(--cosmos-dim); font: 8.5px var(--font-data, var(--mono)); }
.cosmos-evidence .topo-table-scroll { max-height: 34vh; overflow: auto; border: 1px solid var(--cosmos-line); background: var(--cosmos-panel); }

/* motion: every cosmos animation opts in via no-preference */
@media (prefers-reduced-motion: no-preference) {
  .cosmos-pulse { animation: cosmos-pulse-out 2s ease-out infinite; }
  @keyframes cosmos-spin-cw { to { transform: rotate(360deg); } }
  @keyframes cosmos-spin-ccw { to { transform: rotate(-360deg); } }
  @keyframes cosmos-breathe { 0%, 100% { opacity: .06; transform: scale(1); } 50% { opacity: .16; transform: scale(1.06); } }
  @keyframes cosmos-pulse-out { 0% { opacity: .75; transform: scale(1); } 100% { opacity: 0; transform: scale(1.7); } }
  @keyframes cosmos-dash-flow { to { stroke-dashoffset: -80; } }
  @keyframes cosmos-blink { 0%, 100% { opacity: 1; } 50% { opacity: .25; } }
  @keyframes cosmos-twinkle { 0%, 100% { opacity: inherit; } 50% { opacity: .04; } }
}

@media (max-width: 1000px) {
  .cosmos-stage-row { flex-direction: column; }
  .cosmos-detail { width: 100%; max-height: 44vh; border-left: 0; border-top: 1px solid var(--cosmos-line); }
  .cosmos-title { letter-spacing: .2em; }
  .cosmos-topbar { height: auto; padding: 8px 12px; flex-wrap: wrap; }
  .cosmos-title-wrap { position: static; order: -1; width: 100%; padding: 4px 0; }
  .cosmos-stage { min-height: 52vh; }
  .cosmos-foot { flex-wrap: wrap; }
}

/* responsive */
@media (max-width: 1000px) {
  .ws-hero-row { flex-direction: column; }
  .ws-hero-act { flex-direction: row; align-items: center; }
  .today-context { grid-template-columns: 1fr; }
  .today-next { grid-column: auto; grid-template-columns: 1fr; gap: 7px; }
  .approval-item { align-items: flex-start; flex-direction: column; }
  .continuity-hero { grid-template-columns: 1fr; }
  .continuity-map { min-height: 260px; }
  .project-overview-grid { grid-template-columns: 1fr; }
  body { overflow: auto; }
  .shell { flex-direction: column; height: auto; }
  .sidebar { width: 100%; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 10px; }
  #nav { flex-direction: row; flex-wrap: wrap; }
  .side-label, .side-agents, .side-foot { display: none; }
  .main { padding: 18px 14px 50px; }
  .two-col, .detail-grid, .report-grid { grid-template-columns: 1fr; }
  .view-flush.active { height: 70vh; }
  /* horizontal sidebar: the Settings pin joins the nav row */
  .side-settings { margin-top: 0; padding-top: 0; border-top: 0; }
}
@media (max-width: 768px) {
  .graph-bar { grid-template-columns: minmax(0, 1fr); }
  .graph-bar > * { grid-column: 1; }
  .graph-layers, .graph-modes { width: 100%; }
  .graph-open { justify-self: stretch; text-align: center; }
  .graph-focus-bar { align-items: flex-start; flex-direction: column; }
  .continuity-hero { padding: 20px 18px; gap: 20px; }
  .continuity-map { grid-template-columns: 1fr; min-height: 0; gap: 12px; }
  .continuity-map::before, .continuity-core::after { display: none; }
  .continuity-core { min-height: 100px; }
  .continuity-strip { grid-template-columns: 1fr 1fr; }
  .continuity-strip span:nth-child(3) { border-left: 0; border-top: 1px solid var(--line); }
  .continuity-strip span:nth-child(4) { border-top: 1px solid var(--line); }
  .project-panels { min-height: 280px; }
  .ws-composer, .decision-form { display: grid; grid-template-columns: 1fr; align-items: stretch; }
  .ws-composer select, .decision-form input { width: 100%; max-width: none; }
  .project-memory { max-height: none; }
}
@media (max-width: 390px) {
  .graph-bar { padding: 8px; }
  .graph-title { font-size: 15px; }
  .graph-layers, .graph-modes { display: grid; grid-template-columns: 1fr 1fr; border-radius: 9px; }
  .graph-layers .lyr, .graph-modes .lyr { width: 100%; min-width: 0; padding-inline: 6px; font-size: 8.5px; }
  .graph-wrap { min-height: 62vh; }
  .graph-hint { display: none; }
  .continuity-hero { padding: 18px 14px; }
  .continuity-actions { align-items: stretch; flex-direction: column; }
  .continuity-actions :is(.btn,.continuity-link) { width: 100%; }
  .continuity-strip { grid-template-columns: 1fr; }
  .continuity-strip span + span { border-left: 0; border-top: 1px solid var(--line); }
  .project-workspace .detail-actions { width: 100%; margin-left: 0; }
  .project-workspace .detail-actions :is(.btn,.project-link) { width: 100%; }
  .project-section-head { align-items: flex-start; }
  .project-files a { align-items: flex-start; flex-direction: column; gap: 4px; }
  .approval-actions { width: 100%; }
  .approval-actions .btn { width: 100%; min-height: 44px; }
}
