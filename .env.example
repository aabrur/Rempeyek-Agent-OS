# AGENTIC//OS — environment configuration
# Copy to .env and edit. Every variable is optional.

# Dashboard port (default 4321)
PORT=4321

# Absolute path to your Obsidian Vault (the shared memory layer).
# Default: "<repo>\Obsidian Vault"
VAULT_PATH=C:\path\to\your\Obsidian Vault

# Auth token for remote (non-localhost) access. Localhost never needs it.
# Leave unset for local-only use.
DASH_TOKEN=

# Claude Code transcripts folder (for the Sessions/Subagents panels).
# Default: %USERPROFILE%\.claude\projects
CLAUDE_PROJECTS=

# Vault backup location — enables the backup-age row in the Vault Health panel.
BACKUP_PATH=
# Dashboard binds to loopback by default. Remote access is fail-closed.
DASH_HOST=127.0.0.1
DASH_REMOTE=0
# Required when DASH_REMOTE=1. Use a long random value; never commit the real token.
DASH_TOKEN=
# Required when DASH_REMOTE=1; comma-separated exact origins, including scheme and port.
DASH_ALLOWED_ORIGINS=
