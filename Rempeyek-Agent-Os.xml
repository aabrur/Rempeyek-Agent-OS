  --cosmos-status-running:#4f704d; --cosmos-status-idle:#916c2f; --cosmos-status-observe:#916c2f;
  --cosmos-status-error:#9b4c49; --cosmos-status-disabled:#9a9188;
  --cosmos-conn-strong:#366b76; --cosmos-conn-data:#655f87; --cosmos-conn-weak:#b3a794;
  --cosmos-nebula-c:transparent; --cosmos-nebula-v:transparent; --cosmos-nebula-p:transparent;
  --cosmos-star:#48433e; --cosmos-amber:#916c2f; --cosmos-ok:#4f704d;
}
:root[data-theme="brutalist"] {
  --cosmos-canvas:#fff9ed; --cosmos-canvas-mid:#fff9ed;
  --cosmos-panel:#ffe358; --cosmos-line:#171717;
  --cosmos-node-fill:#fffdf8; --cosmos-ink:#111; --cosmos-name:#111;
  --cosmos-body:#2e2a26; --cosmos-dim:#514d46;
  --cosmos-accent:#e23d00; --cosmos-core:#111; --cosmos-core-ring2:#e23d00;
  --cosmos-status-running:#437a22; --cosmos-status-idle:#9a5500; --cosmos-status-observe:#9a5500;
  --cosmos-status-error:#be123c; --cosmos-status-disabled:#68615a;
  --cosmos-conn-strong:#006d77; --cosmos-conn-data:#5535c9; --cosmos-conn-weak:#171717;
  --cosmos-nebula-c:transparent; --cosmos-nebula-v:transparent; --cosmos-nebula-p:transparent;
  --cosmos-star:#171717; --cosmos-amber:#9a5500; --cosmos-ok:#437a22;
}

/* component token application */
:root[data-theme] body { font-family:var(--font-ui); letter-spacing:var(--ui-tracking); }
:root[data-theme] :is(.page-head h1,.brand-name,.graph-title,.ws-hero-name,.agent-name,.tile-val) {
  font-family:var(--font-heading); letter-spacing:var(--heading-tracking); text-transform:var(--heading-case);
}
:root[data-theme] :is(.side-label,.brand-sub,.section-label,.tile-top,.graph-stats,.detail-meta,.theme-name) { font-family:var(--font-data); }
:root[data-theme] .sidebar { width:var(--sidebar-width); padding:var(--sidebar-padding); }
:root[data-theme] .main { padding:var(--page-y) var(--page-x) 60px; }
:root[data-theme] .main.main-flush { padding:0; }
:root[data-theme] :is(.tiles,.agent-row,.two-col,.ws-grid,.today-context,.report-grid) { gap:var(--card-gap); }
:root[data-theme] :is(.tile,.panel,.agent-card,.ws-card,.gw-menu,.token-box,.detail,.aa-box,.today-panel,.approval-queue) {
  border-width:var(--surface-border-width); border-style:var(--surface-border-style); border-color:var(--surface-border);
  border-radius:var(--surface-radius); box-shadow:var(--surface-shadow); background:var(--surface-fill);
  backdrop-filter:blur(var(--surface-blur)); -webkit-backdrop-filter:blur(var(--surface-blur));
}
:root[data-theme] :is(button,input,select,textarea,.chip,.lyr) { border-radius:var(--control-radius); }
:root[data-theme] :is(button,a,input,select,textarea,[tabindex]):focus-visible {
  outline:var(--focus-size) solid var(--acc); outline-offset:var(--focus-offset);
}
:root[data-theme] .graph-wrap { background:var(--graph-canvas); border-radius:var(--surface-radius); }
:root[data-theme] .theme-sw:focus-visible { outline:3px solid var(--acc); outline-offset:3px; }
:root[data-theme] :is(.dot.working,.dot.waiting,.dot.running,.dot.error,.dot.exited) { box-shadow:var(--dom-status-shadow); }
:root[data-theme] :is(.tele-bar,.rep-bar,.ws-prog) { background:var(--dom-rail-fill); }
:root[data-theme] .tele-bar i { background:var(--dom-telemetry-fill); box-shadow:var(--dom-telemetry-shadow); }
:root[data-theme] .rep-bar i { background:var(--dom-report-fill); box-shadow:var(--dom-report-shadow); }
:root[data-theme] :is(.tile-val,.rep-stat .v) { text-shadow:var(--dom-stat-shadow); }
:root[data-theme] .ws-prog i { background:var(--dom-progress-fill); box-shadow:var(--dom-progress-shadow); }
:root[data-theme] .ws-prog-hero::after { display:var(--dom-progress-scan); }
:root[data-theme] .theme-sw::after { box-shadow:var(--dom-swatch-dot-shadow); }
:root[data-theme] .theme-sw.on { box-shadow:var(--dom-swatch-selected-shadow); }
:root[data-theme] .ws-agents i { box-shadow:var(--dom-agent-dot-shadow); }

/* Minimalist component structure */
:root[data-theme="minimalist"] :is(.bg-grid,.bg-glow) { display:none; }
:root[data-theme="minimalist"] .sidebar { background:var(--bg); border-right:1px solid var(--line); }
:root[data-theme="minimalist"] .brand { border-bottom:1px solid var(--line); }
:root[data-theme="minimalist"] .brand-mark { border:0; clip-path:none; box-shadow:none; width:28px; }
:root[data-theme="minimalist"] .nav-item { border:0; border-bottom:1px solid transparent; border-radius:0; padding:11px 2px; font-family:var(--font-ui); letter-spacing:0; }
:root[data-theme="minimalist"] .nav-item:is(:hover,.active) { background:none; color:var(--text); border-bottom-color:var(--text); text-shadow:none; }
:root[data-theme="minimalist"] :is(.page-head h1,.ws-hero-name) { background:none; filter:none; -webkit-text-fill-color:currentColor; color:var(--text); }
:root[data-theme="minimalist"] :is(.tile,.panel,.agent-card,.ws-card,.today-panel) { border-top:1px solid var(--line); border-bottom:0; padding:var(--card-padding); }
:root[data-theme="minimalist"] :is(.tile::before,.ws-hero::before) { display:none; }
:root[data-theme="minimalist"] :is(.tile-val,.section-label,.brand-mark) { text-shadow:none; box-shadow:none; }
:root[data-theme="minimalist"] .ws-hero { border:0; border-left:3px solid var(--acc); border-radius:0; padding:8px 0 8px 24px; background:transparent; box-shadow:none; }
/* keep the accent bar (::before, 3px at x=0) clear of the copy */
:root[data-theme="minimalist"] .continuity-hero { border:0; border-block:1px solid var(--line); border-radius:0; padding-inline:26px 0; }
:root[data-theme="minimalist"] .continuity-core { border:0; border-block:1px solid var(--line); border-radius:0; background:transparent; }
:root[data-theme="minimalist"] .project-composer { border-width:1px 0; background:transparent; }
:root[data-theme="minimalist"] .topo-fallback { background:transparent; box-shadow:none; }

/* Brutalist component structure */
:root[data-theme="brutalist"] .sidebar { background:var(--card-hi); border-right:3px solid var(--line); }
:root[data-theme="brutalist"] .brand { border-bottom:3px solid var(--line); }
:root[data-theme="brutalist"] .brand-mark { color:var(--text); border:3px solid var(--line); clip-path:none; box-shadow:3px 3px 0 var(--acc); }
:root[data-theme="brutalist"] .nav-item { border:2px solid transparent; padding:8px; font-family:var(--font-heading); letter-spacing:-.02em; }
:root[data-theme="brutalist"] .nav-item:is(:hover,.active) { color:#fff; background:#111; border-color:#111; text-shadow:none; }
:root[data-theme="brutalist"] :is(.page-head h1,.ws-hero-name) { background:none; filter:none; -webkit-text-fill-color:currentColor; color:var(--text); }
:root[data-theme="brutalist"] .page-head { border-bottom:4px solid var(--line); padding-bottom:12px; }
:root[data-theme="brutalist"] :is(.tile,.panel,.agent-card,.ws-card,.ws-hero,.graph-wrap) { backdrop-filter:none; background:var(--surface-fill); }
:root[data-theme="brutalist"] :is(.tile::before,.ws-hero::before) { background:var(--line); box-shadow:none; }
:root[data-theme="brutalist"] :is(.tile-val,.section-label,.brand-mark,.rep-stat .v) { text-shadow:none; }
:root[data-theme="brutalist"] :is(.btn,.lyr,.chip) { box-shadow:2px 2px 0 var(--line); font-family:var(--font-heading); }
:root[data-theme="brutalist"] :is(.btn,.lyr,.chip):active { box-shadow:none; transform:translate(2px,2px); }
:root[data-theme="brutalist"] :is(.continuity-core,.project-composer) { border-radius:0; }
:root[data-theme="brutalist"] .continuity-node::before { border-radius:0; }
:root[data-theme="brutalist"] .continuity-core { background:var(--card-hi); border-width:3px; }
:root[data-theme="brutalist"] .project-tabs button.active { color:#fff; background:#111; box-shadow:inset 0 -4px var(--acc); }
:root[data-theme="brutalist"] .topo-fallback { border:3px solid var(--line); border-radius:0; background:var(--card-hi); box-shadow:4px 4px 0 var(--line); }

/* Glass component structure */
:root[data-theme="glassmorph"] body { background:radial-gradient(circle at 75% 5%,#17395a 0,transparent 38%),radial-gradient(circle at 8% 92%,#252552 0,transparent 36%),var(--bg); }
:root[data-theme="glassmorph"] .sidebar { background:rgba(8,22,39,.74); border-right:1px solid rgba(189,224,255,.28); backdrop-filter:blur(24px); }
:root[data-theme="glassmorph"] .nav-item { border-radius:14px; }
:root[data-theme="glassmorph"] .nav-item.active { background:rgba(125,211,252,.13); border:1px solid rgba(189,224,255,.28); border-left-color:var(--acc); text-shadow:none; }
:root[data-theme="glassmorph"] :is(.page-head h1,.ws-hero-name) { filter:none; }
:root[data-theme="glassmorph"] :is(.ws-hero,.graph-wrap) { box-shadow:0 28px 80px rgba(0,0,0,.28),inset 0 1px rgba(255,255,255,.1); }
:root[data-theme="glassmorph"] .continuity-core { background:rgba(125,211,252,.08); box-shadow:inset 0 1px rgba(255,255,255,.09); }
:root[data-theme="glassmorph"] .topo-fallback { background:rgba(7,17,31,.78); backdrop-filter:none; box-shadow:inset 0 1px rgba(255,255,255,.08); }

/* Restrained Cosmos component structure */
:root[data-theme="cyberpunk"] .sidebar { background:linear-gradient(180deg,rgba(3,9,24,.97),rgba(2,6,17,.98)); border-right-color:var(--cosmos-line); }
:root[data-theme="cyberpunk"] :is(.page-head h1,.ws-hero-name) { filter:none; }
:root[data-theme="cyberpunk"] :is(.panel,.tile,.agent-card,.ws-card) { background:var(--surface-fill); backdrop-filter:blur(4px); }
:root[data-theme="cyberpunk"] :is(.nav-item.active,.theme-sw.on,.btn-primary:focus-visible) { text-shadow:0 0 10px color-mix(in srgb,var(--acc) 34%,transparent); }
:root[data-theme="cyberpunk"] .continuity-core { box-shadow:0 0 28px color-mix(in srgb,var(--ac,var(--acc)) 16%,transparent); }
:root[data-theme="cyberpunk"] .continuity-node :is(a,button):focus-visible { box-shadow:0 0 16px color-mix(in srgb,var(--acc) 18%,transparent); }
/* cosmos energy sweep along the continuity hero's top edge */
:root[data-theme="cyberpunk"] .continuity-hero::after {
  content:""; position:absolute; top:0; left:0; right:0; height:2px; pointer-events:none;
  background:linear-gradient(90deg,transparent 12%,var(--acc) 42%,var(--magenta) 58%,transparent 88%);
  background-size:240% 100%; opacity:.85;
}
:root[data-theme="cyberpunk"] .continuity-core { border-color:color-mix(in srgb,var(--ac,var(--acc)) 72%,var(--line)); }
@media (prefers-reduced-motion:no-preference) {
  :root[data-theme="cyberpunk"] .continuity-hero::after { animation:cosmosSweep 7s linear infinite; }
  @keyframes cosmosSweep { from { background-position:200% 0; } to { background-position:-100% 0; } }
  :root[data-theme="cyberpunk"] .continuity-core { animation:coreBreath 5.2s ease-in-out infinite; }
  @keyframes coreBreath {
    0%,100% { box-shadow:0 0 28px color-mix(in srgb,var(--ac,var(--acc)) 16%,transparent); }
    50%     { box-shadow:0 0 40px color-mix(in srgb,var(--ac,var(--acc)) 30%,transparent); }
  }
}

/* responsive structural gates */
@media (max-width:1280px) {
  :root[data-theme] { --sidebar-width:216px; --page-x:22px; --page-y:22px; --card-gap:12px; }

}
@media (max-width:1000px) {
  :root[data-theme] .sidebar { width:100%; flex-direction:row; flex-wrap:wrap; }

}
@media (max-width:768px) {
  :root[data-theme] { --page-x:16px; --page-y:18px; }
  :root[data-theme] .sidebar { width:100%; position:sticky; top:0; z-index:80; padding:10px 12px; border-right:0; border-bottom:1px solid var(--line); }

  :root[data-theme] .brand { padding:0 8px 0 0; border-bottom:0; }
  :root[data-theme] #nav { flex-wrap:nowrap; overflow-x:auto; max-width:100%; }
  :root[data-theme] .nav-item { flex:0 0 auto; width:auto; white-space:nowrap; }
  :root[data-theme] .theme-pick { margin-left:auto; grid-template-columns:repeat(4,34px); gap:5px; padding:0; }
  :root[data-theme] .theme-sw-label,:root[data-theme] .theme-name { position:absolute; width:1px; height:1px; overflow:hidden; clip-path:inset(50%); white-space:nowrap; }
  :root[data-theme] :is(.graph-bar,.approval-head,.section-row) { align-items:flex-start; }
  :root[data-theme] .graph-search { width:min(100%,260px); }
}
@media (max-width:390px) {
  :root[data-theme] { --page-x:12px; --page-y:14px; --card-gap:10px; }
  :root[data-theme] .sidebar { width:100%; display:grid; grid-template-columns:auto 1fr; }

  :root[data-theme] .brand-sub,:root[data-theme] .brand-mark { display:none; }
  :root[data-theme] #nav { grid-column:1 / -1; order:3; }
  :root[data-theme] .nav-item { min-height:44px; padding:8px 9px; font-size:11px; }
  :root[data-theme] .theme-pick { grid-template-columns:repeat(4,44px); }
  :root[data-theme] .theme-sw { min-width:44px; min-height:44px; }
  :root[data-theme] :is(.task-form,.detail-head,.approval-actions,.rep-head-stats) { flex-direction:column; align-items:stretch; }
  :root[data-theme] .detail-actions { margin-left:0; }
}
@media (prefers-reduced-transparency:reduce) {
  :root[data-theme="glassmorph"] { --panel:#0c1b2f; --card:#152a44; --card-hi:#274669; --surface-fill:#152a44; --surface-blur:0px; }
}
@media (prefers-reduced-motion:reduce) {
  :root[data-theme] * { scroll-behavior:auto; }
  :root[data-theme] :is(.theme-sw,.nav-item,.btn,.ws-card) { transition:none; }
}
@media (prefers-contrast:more) { :root { --surface-shadow:none; --focus-size:3px; } }
@media (forced-colors:active) {
  :root { --surface-shadow:none; --surface-blur:0px; }
  .theme-sw.on { outline:3px solid Highlight; }
}
